      2025: { players: ['MS Dhoni', 'Ruturaj Gaikwad', 'Ravindra Jadeja', 'Shivam Dube', 'Deepak Chahar', 'Matheesha Pathirana', 'Rachin Ravindra', 'Daryl Mitchell', 'Devon Conway', 'Moeen Ali', 'Tushar Deshpande', 'Sameer Rizvi', 'Ajinkya Rahane', 'Mukesh Choudhary', 'Shaik Rasheed', 'Nishant Sindhu', 'Rajvardhan Hangargekar'], captain: 'Ruturaj Gaikwad' },
      2026: { players: ['MS Dhoni', 'Ruturaj Gaikwad', 'Sanju Samson', 'Dewald Brevis', 'Shivam Dube', 'Noor Ahmad', 'Rahul Chahar', 'Matthew Short', 'Akeal Hosein', 'Matt Henry', 'Spencer Johnson', 'Gurjapneet Singh', 'Aman Hakim Khan', 'Shreyas Gopal', 'Zak Foulkes', 'Urvil Patel', 'Kartik Sharma', 'Prashant Veer', 'Ramakrishna Ghosh'], captain: 'Ruturaj Gaikwad' }
    };

    const CHAMPION_YEARS = [2008, 2010, 2011, 2018, 2021, 2023];
    const ERAS = [
      { name: 'Foundation Era', years: [2008, 2009, 2010], desc: 'The birth of CSK — three seasons, two titles, a dynasty formed.', trophies: ['🏆 IPL 2008', '🏆 IPL 2010', '🏅 CLT20 2010'] },
      { name: 'Golden Era', years: [2011, 2012, 2013, 2014, 2015], desc: 'Back-to-back glory and consistent dominance across five campaigns.', trophies: ['🏆 IPL 2011', '🏅 CLT20 2014', '🥈 2012 Runners-Up', '🥈 2013 Runners-Up'] },
      { name: 'Comeback Era', years: [2018, 2019, 2020, 2021], desc: 'After suspension, the Kings returned to reclaim their crown — twice.', trophies: ['🏆 IPL 2018', '🥈 IPL 2019', '🏆 IPL 2021'] },
      { name: 'New Generation Era', years: [2022, 2023, 2024, 2025, 2026], desc: 'A new era of leadership and fresh talent, with CSK\'s fifth IPL crown.', trophies: ['🏆 IPL 2023'] }
    ];

    // Extended timeline events
    const XTL_EVENTS = [
      { year: 2008, type: 'champion', icon: '🏆', title: 'Inaugural Champions', desc: 'First ever IPL title. Beat RR in final.' },
      { year: 2009, type: 'normal', icon: '⚡', title: 'CLT20 Debut', desc: 'Strong campaign in both competitions.' },
      { year: 2010, type: 'champion', icon: '🏆', title: 'Double Glory', desc: 'IPL + CLT20 in the same year.', captain: 'MS Dhoni' },
      { year: 2011, type: 'champion', icon: '🏆', title: 'Back-to-Back', desc: 'Second consecutive IPL title. Dominant season.', captain: 'MS Dhoni' },
      { year: 2012, type: 'normal', icon: '🥈', title: 'Runners-Up', desc: 'Beaten by KKR in thriller final.' },
      { year: 2013, type: 'normal', icon: '🥈', title: 'Runners-Up Again', desc: 'MI deny back-to-back for CSK.' },
      { year: 2014, type: 'normal', icon: '🏅', title: 'CLT20 Champions', desc: 'Second CLT20 title.', captain: 'MS Dhoni' },
      { year: 2015, type: 'normal', icon: '⚡', title: 'Quarter Finals', desc: 'Exit in QF; rebuilding phase begins.' },
      { year: 2016, type: 'suspended', icon: '🚫', title: 'Suspended', desc: 'CSK banned for 2016 season.' },
      { year: 2017, type: 'suspended', icon: '🚫', title: 'Suspended', desc: 'Second year of suspension.' },
      { year: 2018, type: 'champion', icon: '🏆', title: 'The Return', desc: 'Triumphal comeback. Third IPL title.', captain: 'MS Dhoni' },
      { year: 2019, type: 'normal', icon: '🥈', title: 'Runners-Up', desc: 'Lost to MI by 1 run. Heartbreak.' },
      { year: 2020, type: 'normal', icon: '😞', title: '7th Place', desc: 'A rare below-par campaign; seeds of 2021 sown.' },
      { year: 2021, type: 'champion', icon: '🏆', title: '4th Title', desc: 'Gaikwad runs, Dhoni finishes. Back on top.', captain: 'MS Dhoni' },
      { year: 2022, type: 'normal', icon: '⚡', title: 'Jadeja Captains', desc: 'Jadeja leads midway; Dhoni takes over.', captain: 'Jadeja → Dhoni' },
      { year: 2023, type: 'champion', icon: '🏆', title: 'Five Stars', desc: 'Dhoni helicopter. Final over heroics. 5th title.', captain: 'MS Dhoni' },
      { year: 2024, type: 'normal', icon: '⚡', title: 'New Captain', desc: 'Ruturaj Gaikwad leads CSK into new era.', captain: 'Ruturaj Gaikwad' },
      { year: 2025, type: 'normal', icon: '⚡', title: 'Defending Champions', desc: 'The quest for title No.6 continues.', captain: 'Ruturaj Gaikwad' },
      { year: 2026, type: 'normal', icon: '🦁', title: 'New Generation', desc: 'Fresh squad, same yellow ambition.', captain: 'Ruturaj Gaikwad' }
    ];

    // ─── Build Archive ──────────────────────────────────────────────────────────
    function buildArchive() {
      const nav = document.getElementById('archive-nav');
      const content = document.getElementById('archive-content');
      if (!nav || !content) return;

      let navHTML = '';
      let contentHTML = '';
      const years = Object.keys(PLAYERS).map(Number);

      // Era markers
      const eraStarts = {};
      ERAS.forEach(e => { eraStarts[e.years[0]] = e; });

      years.forEach(yr => {
        const d = PLAYERS[yr];
        const isChamp = CHAMPION_YEARS.includes(yr);
        const isSus = d.suspended;
        const count = d.players ? d.players.length : 0;

        // Nav item
        navHTML += `<span class="archive-nav-year ${isSus ? 'suspended' : ''}" onclick="scrollToYear(${yr})" id="nav-${yr}">${yr}${isChamp ? '<span class="champ-dot"></span>' : ''}</span>`;

        // Era banner
        if (eraStarts[yr]) {
          const era = eraStarts[yr];
          contentHTML += `<div class="era-banner"><div class="era-banner-title">${era.name}</div><div class="era-banner-subtitle">${era.desc}</div><div class="era-trophies">${era.trophies.map(t => `<span class="era-trophy-chip">${t}</span>`).join('')}</div></div>`;
        }

        // Year section
        contentHTML += `<div class="year-section" id="year-${yr}">
      <div class="year-header" onclick="toggleYear(${yr})">
        <div class="year-header-num">${yr}</div>
        <div class="year-header-info">
          <div class="year-header-label">${isSus ? 'Suspended Season' : d.captain ? `Captain: ${d.captain}` : 'Season Squad'}</div>
          <div class="year-header-count">${isSus ? '' : count + ' players'}</div>
        </div>
        ${isChamp ? '<div class="champ-badge">🏆 Champions</div>' : ''}
        <div class="year-toggle">▼</div>
      </div>`;

        if (isSus) {
          contentHTML += `<div class="suspension-card"><div class="suspension-card-icon">🚫</div><div class="suspension-card-text">Chennai Super Kings were suspended from the IPL for the ${yr} season.</div></div>`;
        } else {
          contentHTML += `<div class="player-grid" id="grid-${yr}">`;
          d.players.forEach((p, i) => {
            contentHTML += `<div class="player-card" data-name="${p.toLowerCase()}"><div class="player-num">${i + 1}</div><div class="player-card-name">${p}</div></div>`;
          });
          contentHTML += `</div>`;
        }
        contentHTML += `</div>`;
      });

      nav.innerHTML = navHTML;
      content.innerHTML = contentHTML;
    }

    function toggleYear(yr) {
      const sec = document.getElementById(`year-${yr}`);
      if (sec) sec.classList.toggle('collapsed');
    }

    function scrollToYear(yr) {
      const el = document.getElementById(`year-${yr}`);
      if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      document.querySelectorAll('.archive-nav-year').forEach(n => n.classList.remove('active'));
      const navEl = document.getElementById(`nav-${yr}`);
      if (navEl) navEl.classList.add('active');
    }

    function filterPlayers(query) {
      const q = query.toLowerCase().trim();
      const years = Object.keys(PLAYERS).map(Number);
      years.forEach(yr => {
        const d = PLAYERS[yr];
        if (d.suspended) return;
        const grid = document.getElementById(`grid-${yr}`);
        if (!grid) return;
        const cards = grid.querySelectorAll('.player-card');
        let matchCount = 0;
        cards.forEach(c => {
          const name = c.getAttribute('data-name') || '';
          const show = !q || name.includes(q);
          c.style.display = show ? '' : 'none';
          if (show) matchCount++;
        });
        const sec = document.getElementById(`year-${yr}`);
        if (sec) {
          if (q && matchCount === 0) { sec.style.display = 'none'; }
          else {
            sec.style.display = '';
            if (q && matchCount > 0) sec.classList.remove('collapsed');
          }
        }
      });
    }

    // ─── Build Extended Timeline ────────────────────────────────────────────────
    function buildXTimeline() {
      const track = document.getElementById('xtl-track');
      if (!track) return;
      let html = '';
      XTL_EVENTS.forEach(e => {
        html += `<div class="xtl-item ${e.type}" id="xtl-${e.year}">
      <div class="xtl-trophy-icon">${e.icon}</div>
      <div class="xtl-dot-wrap"><div class="xtl-dot"></div></div>
      <div class="xtl-year">${e.year}</div>
      <div class="xtl-title">${e.title}</div>
      <div class="xtl-desc">${e.desc}</div>
      ${e.captain ? `<div class="xtl-captain">⚑ ${e.captain}</div>` : ''}
    </div>`;
      });
      track.innerHTML = html;

      // Drag scroll
      const scroll = document.getElementById('xtl-scroll');
      if (!scroll) return;
      let isDown = false, startX, scrollLeft;
      scroll.addEventListener('mousedown', e => { isDown = true; startX = e.pageX - scroll.offsetLeft; scrollLeft = scroll.scrollLeft; });
      scroll.addEventListener('mouseleave', () => isDown = false);
      scroll.addEventListener('mouseup', () => isDown = false);
      scroll.addEventListener('mousemove', e => {
        if (!isDown) return; e.preventDefault();
        const x = e.pageX - scroll.offsetLeft;
        scroll.scrollLeft = scrollLeft - (x - startX) * 1.5;
      });
    }

    // ─── Trophy counters animation ──────────────────────────────────────────────
    function animateCounter(id, target, duration) {
      const el = document.getElementById(id);
      if (!el) return;
      let start = 0;
      const step = (timestamp) => {
        if (!start) start = timestamp;
        const progress = Math.min((timestamp - start) / duration, 1);
        el.textContent = Math.floor(progress * target);
        if (progress < 1) requestAnimationFrame(step);
        else el.textContent = target;
      };
      requestAnimationFrame(step);
    }

    // Init archive counter observers
    function observeCounters() {
      const ipl = document.getElementById('ipl-counter');
      if (!ipl) return;
      if (!ipl) return;
      const obs = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            animateCounter('ipl-counter', 5, 1200);
            animateCounter('clt-counter', 2, 900);
            animateCounter('total-counter', 7, 1500);
            obs.disconnect();
          }
        });
      }, { threshold: 0.5 });
      obs.observe(ipl);
    }

    // Update nav links in navbar
    function updateNavLinks() {
      const linksEl = document.querySelector('.nav-links');
      if (!linksEl) return;
      linksEl.innerHTML = `
    <li><a href="#legacy">Legacy</a></li>
    <li><a href="#squad2026">Squad</a></li>
    <li><a href="#players-archive">Archive</a></li>
    <li><a href="#titles">Trophies</a></li>
    <li><a href="#fixtures">Fixtures</a></li>
    <li><a href="#fanzone">Fan Zone</a></li>
  `;
    }

    // Highlight active archive year on scroll
    function setupArchiveScrollSpy() {
      const years = Object.keys(PLAYERS).map(Number);
      const observer = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            const yr = e.target.id.replace('year-', '');
            document.querySelectorAll('.archive-nav-year').forEach(n => n.classList.remove('active'));
            const navEl = document.getElementById('nav-' + yr);
            if (navEl) { navEl.classList.add('active'); navEl.scrollIntoView({ block: 'nearest' }); }
          }
        });
      }, { rootMargin: '-30% 0px -60% 0px' });
      try { years.forEach(yr => { const el = document.getElementById('year-' + yr); if (el) observer.observe(el); }); } catch (e) { }
    }

    // Run everything on DOM ready
    document.addEventListener('DOMContentLoaded', () => {
      buildArchive();
      buildXTimeline();
      observeCounters();
      updateNavLinks();
      setTimeout(setupArchiveScrollSpy, 500);

      // Add cursor hover to legend cards
      document.querySelectorAll('.legend-card').forEach(function (el) {
        el.addEventListener('mouseenter', () => {
          const ring = document.getElementById('cursor-ring');
          if (ring) { ring.style.width = '60px'; ring.style.height = '60px'; ring.style.borderColor = 'rgba(253,185,19,0.8)'; }
        });
        el.addEventListener('mouseleave', () => {
          const ring = document.getElementById('cursor-ring');
          if (ring) { ring.style.width = '36px'; ring.style.height = '36px'; ring.style.borderColor = 'var(--gold)'; }
        });
      });
    });


    // ═══ SQUAD 2026 CAROUSEL ════════════════════════════════════════════
    let sq26Current = 0;
    function initSq26() {
      sq26Current = 0;
    }
    (function () {
      const track = document.getElementById('sq26-track');
      const prevBtn = document.getElementById('sq26-prev');
      const nextBtn = document.getElementById('sq26-next');
      const dotsEl = document.getElementById('sq26-dots');
      if (!track || !prevBtn || !nextBtn || !dotsEl) return;

      const cards = track.querySelectorAll('.squad2026-card');
      const TOTAL = cards.length;
      const VISIBLE = () => window.innerWidth < 700 ? 2 : window.innerWidth < 1100 ? 3 : window.innerWidth < 1400 ? 4 : 5;
      let current = 0;
      let maxIdx = () => Math.max(0, TOTAL - VISIBLE());

      // Build dots
      const numDots = () => Math.ceil(TOTAL / VISIBLE());
      function buildDots() {
        dotsEl.innerHTML = '';
        for (let i = 0; i < numDots(); i++) {
          const d = document.createElement('div');
          d.className = 'sq26-dot' + (i === 0 ? ' active' : '');
          d.addEventListener('click', () => goTo(i * VISIBLE()));
          dotsEl.appendChild(d);
        }
      }
      buildDots();

      function updateDots() {
        const dotIndex = Math.min(Math.round(current / VISIBLE()), numDots() - 1);
        dotsEl.querySelectorAll('.sq26-dot').forEach((d, i) => d.classList.toggle('active', i === dotIndex));
      }

      function getCardWidth() {
        const c = track.querySelector('.squad2026-card');
        if (!c) return 236;
        const style = getComputedStyle(c);
        return c.offsetWidth + parseInt(style.marginRight || 0) + 16;
      }

      function goTo(idx) {
        current = Math.max(0, Math.min(idx, maxIdx()));
        track.style.transform = `translateX(-${current * getCardWidth()}px)`;
        prevBtn.disabled = current === 0;
        nextBtn.disabled = current >= maxIdx();
        updateDots();
      }

      prevBtn.addEventListener('click', () => goTo(current - VISIBLE()));
      nextBtn.addEventListener('click', () => goTo(current + VISIBLE()));
      goTo(0);
      window.addEventListener('resize', () => { buildDots(); goTo(current); });

      // Drag/touch
      let startX = 0, isDragging = false, startScrollLeft = 0;
      track.addEventListener('mousedown', e => { isDragging = true; startX = e.pageX; startScrollLeft = current; track.style.transition = 'none'; });
      document.addEventListener('mouseup', e => {
        if (!isDragging) return;
        isDragging = false;
        track.style.transition = '';
        const diff = startX - e.pageX;
        if (Math.abs(diff) > 60) goTo(diff > 0 ? current + VISIBLE() : current - VISIBLE());
        else goTo(current);
      });
      document.addEventListener('mousemove', e => {
        if (!isDragging) return;
        e.preventDefault();
        const dx = startX - e.pageX;
        track.style.transform = `translateX(-${startScrollLeft * getCardWidth() + dx}px)`;
      });
      // Touch
      track.addEventListener('touchstart', e => { startX = e.touches[0].clientX; startScrollLeft = current; track.style.transition = 'none'; }, { passive: true });
      track.addEventListener('touchend', e => {
        track.style.transition = '';
        const diff = startX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 50) goTo(diff > 0 ? current + VISIBLE() : current - VISIBLE());
        else goTo(current);
      });
    })();


    // ── Squad 2026 Filter ──────────────────────────────────────────────
    document.querySelectorAll('.sq26-filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.sq26-filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const filter = btn.dataset.filter;
        const cards = document.querySelectorAll('.squad2026-card');
        cards.forEach(card => {
          const match = filter === 'all' || card.dataset.type === filter;
          card.classList.toggle('sq26-hidden', !match);
        });
        // Reset carousel position
        const track = document.getElementById('sq26-track');
        if (track) { track.style.transform = 'translateX(0)'; }
        // Re-init carousel
        if (typeof initSq26 === 'function') initSq26();
      });
    });


    // ═══ FIXTURES CAROUSEL ════════════════════════════════════════════
    (function () {
      const track = document.getElementById('fxt-track');
      const dotsWrap = document.getElementById('fxt-dots');
      const prevBtn = document.getElementById('fxt-prev');
      const nextBtn = document.getElementById('fxt-next');
      if (!track || !prevBtn || !nextBtn || !dotsWrap) return;
      const cards = track.querySelectorAll('.fxt-card');
      const cardWidth = () => cards[0].offsetWidth + parseInt(getComputedStyle(track).gap);
      const visible = () => Math.floor(track.parentElement.offsetWidth / cardWidth()) || 1;
      let cur = 0;
      const max = () => Math.max(0, cards.length - visible());
      const dots = [];
      for (let i = 0; i <= max(); i++) {
        const d = document.createElement('div'); d.className = 'fxt-dot';
        d.addEventListener('click', () => go(i));
        dotsWrap.appendChild(d); dots.push(d);
      }
      function go(n) { cur = Math.max(0, Math.min(n, max())); track.style.transform = `translateX(-${cur * cardWidth()}px)`; dots.forEach((d, i) => d.classList.toggle('active', i === cur)); }
      go(0);
      prevBtn.addEventListener('click', () => go(cur - 1));
      nextBtn.addEventListener('click', () => go(cur + 1));
      let sx = 0;
      track.addEventListener('mousedown', e => { sx = e.clientX; });
      track.addEventListener('mouseup', e => { const dx = sx - e.clientX; if (Math.abs(dx) > 40) go(dx > 0 ? cur + 1 : cur - 1); });
      track.addEventListener('touchstart', e => { sx = e.touches[0].clientX; }, { passive: true });
      track.addEventListener('touchend', e => { const dx = sx - e.changedTouches[0].clientX; if (Math.abs(dx) > 40) go(dx > 0 ? cur + 1 : cur - 1); }, { passive: true });
      window.addEventListener('resize', () => go(Math.min(cur, max())));
    })();


    // ═══ SEASON CHRONICLE DRAG ═══════════════════════════════════════
    (function () {
      const track = document.getElementById('chr-track');
      if (!track) return;
      let isDragging = false, startX = 0, scrollLeft = 0;
      const el = track ? track.parentElement : null;
      if (!el) return;
      el.addEventListener('mousedown', e => { isDragging = true; startX = e.pageX - el.offsetLeft; scrollLeft = el.scrollLeft; el.style.cursor = 'grabbing'; });
      window.addEventListener('mouseup', () => { isDragging = false; el.style.cursor = ''; });
      el.addEventListener('mousemove', e => { if (!isDragging) return; e.preventDefault(); const x = e.pageX - el.offsetLeft; el.scrollLeft = scrollLeft - (x - startX); });
      el.addEventListener('touchstart', e => { startX = e.touches[0].pageX; scrollLeft = el.scrollLeft; }, { passive: true });
      el.addEventListener('touchmove', e => { const x = e.touches[0].pageX; el.scrollLeft = scrollLeft - (x - startX); }, { passive: true });
    })();

    // ═══ FAIR PLAY CAROUSEL (Disabled - Grid Layout) ═════════════════════
    /*
    (function () {
      const track = document.getElementById('fp-track');
      const dotsWrap = document.getElementById('fp-dots');
