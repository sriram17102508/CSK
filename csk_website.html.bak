  <!-- FAN ZONE -->
  <section id="fanzone" style="background:var(--bg2);padding:40px 0 36px;">
    <div style="padding:0 8vw 28px;">
      <div class="section-tag reveal">The 12th Man</div>
      <div class="section-title reveal">Fan<br><span>Zone</span></div>
    </div>

    <!-- ── TABS ── -->
    <div class="fz-tabs reveal" style="padding:0 8vw;margin-bottom:28px;">
      <button class="fz-tab active" onclick="fzTab(this,'fz-quiz')">🏏 CSK Quiz</button>
      <button class="fz-tab" onclick="fzTab(this,'fz-findplayer')">🔍 Find the Player</button>
      <button class="fz-tab" onclick="fzTab(this,'fz-wall')">💬 Fan Wall</button>
      <button class="fz-tab" onclick="fzTab(this,'fz-polls')">📊 Polls</button>
    </div>

    <!-- ── QUIZ ── -->
    <div id="fz-quiz" class="fz-panel" style="padding:0 8vw;">
      <div class="fz-quiz-card">
        <div class="fz-quiz-header">
          <div>
            <div class="fz-quiz-title">CSK Champions Quiz</div>
            <div class="fz-quiz-sub">10 questions · Test your Yellow Army knowledge</div>
          </div>
          <div class="fz-quiz-score-wrap">
            <div class="fz-timer" id="fz-timer">01:00</div>
            <div class="fz-score-label">Score: <span id="fz-score">0</span>/10</div>
          </div>
        </div>
        <div id="fz-quiz-body">
          <div class="fz-question-wrap">
            <div class="fz-q-num" id="fz-qnum">Question 1 of 10</div>
            <div class="fz-q-text" id="fz-qtext">Loading...</div>
            <div class="fz-options" id="fz-options"></div>
            <div class="fz-q-feedback" id="fz-feedback"></div>
          </div>
        </div>
        <div id="fz-leaderboard" style="display:none;">
          <div class="fz-lb-title">🏆 Leaderboard</div>
          <div class="fz-lb-list" id="fz-lb-list"></div>
          <button class="fz-btn-restart" onclick="fzQuizRestart()">Play Again</button>
        </div>
      </div>
    </div>

    <!-- ── FIND THE PLAYER ── -->
    <div id="fz-findplayer" class="fz-panel" style="display:none;padding:0 8vw;">
      <div class="fz-quiz-card">
        <div class="fz-quiz-title" style="margin-bottom:4px;">🔍 Find the Player</div>
        <div class="fz-quiz-sub" style="margin-bottom:20px;">Use hints to guess the mystery CSK player</div>
        <div class="fz-fp-hints" id="fp-hints-list"></div>
        <div class="fz-fp-reveal" id="fp-reveal" style="display:none;"></div>
        <div class="fz-fp-input-wrap">
          <input id="fp-guess" class="fz-fp-input" placeholder="Type player name..." autocomplete="off">
          <button class="fz-fp-btn" onclick="fpSubmit()">Guess</button>
          <button class="fz-fp-btn fz-fp-hint-btn" onclick="fpHint()">💡 Hint</button>
        </div>
        <div id="fp-feedback" class="fz-q-feedback"></div>
        <button class="fz-btn-restart" style="margin-top:16px;" onclick="fpNext()">Next Player →</button>
      </div>
    </div>

    <!-- ── FAN WALL ── -->
    <div id="fz-wall" class="fz-panel" style="display:none;padding:0 8vw;">
      <div class="fan-grid">
        <div class="fan-card">
          <div class="fan-quote">"Watching CSK win the 2023 final was the greatest moment of my life. The last-ball six
            had me in tears. Whistle Podu forever!"</div>
          <div class="fan-author">
            <div class="fan-avatar">AR</div>
            <div>
              <div class="fan-name">Arjun Raj</div>
              <div class="fan-city">Chennai, Tamil Nadu</div>
            </div>
          </div>
        </div>
        <div class="fan-card">
          <div class="fan-quote">"No team in cricket history has the aura of CSK. Every year they come back stronger,
            smarter, yellower. Thala for a reason!"</div>
          <div class="fan-author">
            <div class="fan-avatar">PS</div>
            <div>
              <div class="fan-name">Priya Subramanian</div>
              <div class="fan-city">Coimbatore, Tamil Nadu</div>
            </div>
          </div>
        </div>
        <div class="fan-card">
          <div class="fan-quote">"I flew from Dubai just to watch Dhoni play at Chepauk. The atmosphere, the passion,
            the yellow ocean — nothing compares."</div>
          <div class="fan-author">
            <div class="fan-avatar">VK</div>
            <div>
              <div class="fan-name">Vikram Kumar</div>
              <div class="fan-city">Dubai, UAE</div>
            </div>
          </div>
        </div>
        <div class="fan-card">
          <div class="fan-quote">"CSK isn't just a team, it's a culture. A family. When you wear that yellow jersey, you
            belong to something bigger than cricket."</div>
          <div class="fan-author">
            <div class="fan-avatar">NM</div>
            <div>
              <div class="fan-name">Nandita Menon</div>
              <div class="fan-city">Kochi, Kerala</div>
            </div>
          </div>
        </div>
        <div class="fan-card">
          <div class="fan-quote">"Five titles and still counting. MSD's calm under pressure is superhuman. No one does
            it like the Super Kings. Ever."</div>
          <div class="fan-author">
            <div class="fan-avatar">ST</div>
            <div>
              <div class="fan-name">Suresh Tamilarasan</div>
              <div class="fan-city">Tiruppur, Tamil Nadu</div>
            </div>
          </div>
        </div>
        <div class="fan-card">
          <div class="fan-quote">"I grew up watching Dhoni win titles. Now I'm raising my son as a CSK fan too. It's not
            a choice, it's a birthright."</div>
          <div class="fan-author">
            <div class="fan-avatar">RD</div>
            <div>
              <div class="fan-name">Rajesh Duraisamy</div>
              <div class="fan-city">Madurai, Tamil Nadu</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── POLLS ── -->
    <div id="fz-polls" class="fz-panel" style="display:none;padding:0 8vw;">
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px;max-width:900px;">

        <div class="fz-poll-card">
          <div class="fz-poll-q">Who is CSK's greatest ever captain?</div>
          <div class="fz-poll-opt" onclick="fzVote(this,82)"><span>MS Dhoni</span>
            <div class="fz-poll-bar" style="width:82%"></div><span class="fz-poll-pct">82%</span>
          </div>
          <div class="fz-poll-opt" onclick="fzVote(this,11)"><span>Suresh Raina (caretaker)</span>
            <div class="fz-poll-bar" style="width:11%"></div><span class="fz-poll-pct">11%</span>
          </div>
          <div class="fz-poll-opt" onclick="fzVote(this,7)"><span>Ruturaj Gaikwad</span>
            <div class="fz-poll-bar" style="width:7%"></div><span class="fz-poll-pct">7%</span>
          </div>
          <div class="fz-poll-votes">Votes: 12,847</div>
        </div>

        <div class="fz-poll-card">
          <div class="fz-poll-q">Best CSK IPL final moment?</div>
          <div class="fz-poll-opt" onclick="fzVote(this,45)"><span>2023 Jadeja last-over heroics</span>
            <div class="fz-poll-bar" style="width:45%"></div><span class="fz-poll-pct">45%</span>
          </div>
          <div class="fz-poll-opt" onclick="fzVote(this,32)"><span>2011 Dhoni helicopter shot</span>
            <div class="fz-poll-bar" style="width:32%"></div><span class="fz-poll-pct">32%</span>
          </div>
          <div class="fz-poll-opt" onclick="fzVote(this,23)"><span>2018 Watson century</span>
            <div class="fz-poll-bar" style="width:23%"></div><span class="fz-poll-pct">23%</span>
          </div>
          <div class="fz-poll-votes">Votes: 9,413</div>
        </div>

        <div class="fz-poll-card">
          <div class="fz-poll-q">Will CSK win IPL 2027?</div>
          <div class="fz-poll-opt" onclick="fzVote(this,71)"><span>Definitely! Whistle Podu!</span>
            <div class="fz-poll-bar" style="width:71%"></div><span class="fz-poll-pct">71%</span>
          </div>
          <div class="fz-poll-opt" onclick="fzVote(this,18)"><span>Maybe, tough competition</span>
