<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Chennai Super Kings — Official</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link
    href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,600;0,700;0,800;0,900;1,700;1,800;1,900&family=Poppins:wght@300;400;500;600&display=swap"
    rel="stylesheet">
  <style>
    :root {
      --gold: #FDB913;
      --gold-dim: rgba(253, 185, 19, 0.15);
      --blue: #0047A0;
      --blue-light: #1a6fd4;
      --bg: #060810;
      --bg2: #080c18;
      --text: #e8eaf0;
      --muted: rgba(232, 234, 240, 0.5);
      --border: rgba(253, 185, 19, 0.2);
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Poppins', sans-serif;
      background: var(--bg);
      color: var(--text);
      overflow-x: hidden;
      cursor: none;
    }

    /* CUSTOM CURSOR */
    #cursor {
      position: fixed;
      width: 10px;
      height: 10px;
      background: var(--gold);
      border-radius: 50%;
      pointer-events: none;
      z-index: 99999;
      transform: translate(-50%, -50%);
      transition: transform 0.1s;
      mix-blend-mode: screen;
    }

    #cursor-ring {
      position: fixed;
      width: 36px;
      height: 36px;
      border: 1.5px solid var(--gold);
      border-radius: 50%;
      pointer-events: none;
      z-index: 99998;
      transform: translate(-50%, -50%);
      transition: all 0.15s ease;
      opacity: 0.6;
    }

    /* SCANLINE */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0, 0, 0, 0.03) 2px, rgba(0, 0, 0, 0.03) 4px);
      pointer-events: none;
      z-index: 9998;
    }

    /* NAVBAR */
    nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 48px;
      height: 72px;
      transition: background 0.4s, backdrop-filter 0.4s;
    }

    nav.scrolled {
      background: rgba(6, 8, 16, 0.85);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
    }

    .nav-logo img {
      height: 52px;
      width: auto;
      filter: drop-shadow(0 0 12px rgba(253, 185, 19, 0.4));
    }

    .nav-links {
      display: flex;
      gap: 36px;
      list-style: none;
    }

    .nav-links a {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 600;
      font-size: 15px;
      letter-spacing: 0.1em;
      color: var(--muted);
      text-decoration: none;
      text-transform: uppercase;
      transition: color 0.2s;
    }

    .nav-links a:hover {
      color: var(--gold);
    }

    .nav-right {
      display: flex;
      align-items: center;
      gap: 20px;
    }

    .live-badge {
      display: flex;
      align-items: center;
      gap: 6px;
      background: rgba(255, 40, 40, 0.15);
      border: 1px solid rgba(255, 40, 40, 0.4);
      padding: 5px 12px;
      border-radius: 4px;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.15em;
      color: #ff4444;
      text-transform: uppercase;
    }

    .live-dot {
      width: 7px;
      height: 7px;
      background: #ff4444;
      border-radius: 50%;
      animation: pulse-red 1.2s infinite;
    }

    @keyframes pulse-red {

      0%,
      100% {
        opacity: 1;
        transform: scale(1);
      }

      50% {
        opacity: 0.4;
        transform: scale(0.7);
      }
    }

    .btn-angled {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 14px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--bg);
      text-decoration: none;
      background: var(--gold);
      padding: 11px 28px;
      clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
      transition: all 0.2s;
      display: inline-block;
    }

    .btn-angled:hover {
      background: #ffe066;
      transform: translateY(-1px);
      box-shadow: 0 8px 30px rgba(253, 185, 19, 0.4);
    }

    /* HERO */
    #hero {
      position: relative;
      height: 100vh;
      min-height: 700px;
      display: flex;
      align-items: center;
      overflow: hidden;
      background: var(--bg);
    }

    .hero-grid {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(253, 185, 19, 0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(253, 185, 19, 0.04) 1px, transparent 1px);
      background-size: 60px 60px;
      animation: grid-move 20s linear infinite;
    }

    @keyframes grid-move {
      0% {
        transform: translate(0, 0);
      }

      100% {
        transform: translate(60px, 60px);
      }
    }

    .hero-radial {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 60% 70% at 65% 50%, rgba(0, 71, 160, 0.25) 0%, transparent 70%),
        radial-gradient(ellipse 40% 50% at 30% 80%, rgba(253, 185, 19, 0.08) 0%, transparent 60%);
    }

    .hero-bg-name {
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      font-family: 'Barlow Condensed', sans-serif;
      font-style: italic;
      font-weight: 900;
      font-size: clamp(140px, 22vw, 340px);
      line-height: 0.82;
      color: transparent;
      -webkit-text-stroke: 1px rgba(253, 185, 19, 0.12);
      letter-spacing: -0.02em;
      text-transform: uppercase;
      white-space: nowrap;
      pointer-events: none;
      z-index: 1;
      user-select: none;
    }

    .hero-player {
      position: absolute;
      right: 0;
      bottom: 0;
      height: 95%;
      z-index: 3;
      pointer-events: none;
      filter: drop-shadow(-20px 0 60px rgba(253, 185, 19, 0.3));
    }

    .hero-player img {
      height: 100%;
      width: auto;
      object-fit: contain;
      display: block;
    }

    .hero-content {
      position: relative;
      z-index: 4;
      padding-left: 8vw;
      max-width: 620px;
    }

    .hero-tag {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 13px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .hero-tag::before {
      content: '';
      display: block;
      width: 32px;
      height: 2px;
      background: var(--gold);
    }

    .hero-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-style: italic;
      font-weight: 900;
      font-size: clamp(56px, 7vw, 110px);
      line-height: 0.88;
      text-transform: uppercase;
      color: #fff;
      margin-bottom: 8px;
    }

    .hero-name span {
      color: var(--gold);
    }

    .hero-role {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 600;
      font-size: 18px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 36px;
    }

    .stat-chips {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 44px;
    }

    .chip {
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid var(--border);
      padding: 12px 20px;
      backdrop-filter: blur(10px);
      clip-path: polygon(6px 0%, 100% 0%, calc(100% - 6px) 100%, 0% 100%);
    }

    .chip-val {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 32px;
      color: var(--gold);
      line-height: 1;
    }

    .chip-label {
      font-size: 10px;
      font-weight: 500;
      color: var(--muted);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-top: 2px;
    }

    .hero-glow {
      position: absolute;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(253, 185, 19, 0.15) 0%, transparent 70%);
      border-radius: 50%;
      z-index: 2;
      pointer-events: none;
      left: 4vw;
      top: 50%;
      transform: translateY(-50%);
      animation: glow-pulse 3s ease-in-out infinite;
    }

    @keyframes glow-pulse {

      0%,
      100% {
        opacity: 0.6;
        transform: translateY(-50%) scale(1);
      }

      50% {
        opacity: 1;
        transform: translateY(-50%) scale(1.1);
      }
    }

    /* MARQUEE */
    .marquee-strip {
      background: var(--gold);
      padding: 14px 0;
      overflow: hidden;
      position: relative;
      z-index: 10;
    }

    .marquee-track {
      display: flex;
      gap: 0;
      animation: marquee 25s linear infinite;
      white-space: nowrap;
    }

    .marquee-item {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 16px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--bg);
      padding: 0 32px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .marquee-item::after {
      content: '★';
      color: rgba(6, 8, 16, 0.3);
    }

    @keyframes marquee {
      0% {
        transform: translateX(0);
      }

      100% {
        transform: translateX(-50%);
      }
    }

    /* LIVE TICKER */
    .ticker-bar {
      background: var(--bg2);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: stretch;
      overflow: hidden;
    }

    .ticker-label {
      background: var(--blue);
      padding: 0 24px;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 13px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #fff;
      display: flex;
      align-items: center;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .ticker-scroll {
      overflow: hidden;
      flex: 1;
      padding: 14px 0;
    }

    .ticker-inner {
      display: flex;
      animation: ticker 30s linear infinite;
      gap: 0;
    }

    .ticker-match {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 600;
      font-size: 16px;
      padding: 0 40px;
      color: var(--text);
      white-space: nowrap;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .ticker-match .tscore {
      color: var(--gold);
      font-weight: 800;
    }

    .ticker-divider {
      color: var(--border);
    }

    @keyframes ticker {
      0% {
        transform: translateX(0);
      }

      100% {
        transform: translateX(-50%);
      }
    }

    /* SECTIONS */
    section {
      padding: 40px 8vw 28px;
      position: relative;
    }

    .section-tag {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 12px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .section-tag::before {
      content: '';
      width: 24px;
      height: 2px;
      background: var(--gold);
      display: block;
    }

    .section-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-style: italic;
      font-size: clamp(48px, 6vw, 96px);
      line-height: 0.9;
      text-transform: uppercase;
      color: #fff;
      margin-bottom: 16px;
    }

    .section-title span {
      color: var(--gold);
    }

    /* LEGACY */
    #legacy {
      background: var(--bg2);
    }

    .legacy-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }

    .legacy-text p {
      color: var(--muted);
      font-size: 16px;
      line-height: 1.8;
      margin-bottom: 16px;
    }

    .legacy-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2px;
      margin-top: 0;
    }

    .lstat {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid var(--border);
      padding: 32px 28px;
      transition: background 0.2s;
    }

    .lstat:hover {
      background: var(--gold-dim);
    }

    .lstat-val {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 64px;
      color: var(--gold);
      line-height: 1;
    }

    .lstat-label {
      font-size: 13px;
      color: var(--muted);
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-top: 6px;
    }

    /* SQUAD */
    #squad {
      background: var(--bg);
    }

    .squad-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      grid-template-rows: 1fr 1fr;
      gap: 3px;
      height: 680px;
    }

    .squad-card {
      position: relative;
      overflow: hidden;
      background: var(--bg2);
      cursor: none;
    }

    .squad-card:first-child {
      grid-row: 1 / 3;
    }

    .squad-card-bg {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, var(--bg2) 0%, rgba(0, 71, 160, 0.2) 100%);
    }

    .squad-card-img {
      position: absolute;
      bottom: 0;
      right: 0;
      height: 90%;
      object-fit: contain;
      filter: grayscale(0.3) contrast(1.1);
      transition: transform 0.5s ease, filter 0.4s;
    }

    .squad-card:hover .squad-card-img {
      transform: scale(1.05);
      filter: grayscale(0) contrast(1.2);
    }

    .squad-card-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(6, 8, 16, 0.95) 0%, rgba(6, 8, 16, 0.4) 40%, transparent 70%);
      transition: background 0.4s;
    }

    .squad-card:hover .squad-card-overlay {
      background: linear-gradient(to top, rgba(6, 8, 16, 0.98) 0%, rgba(0, 71, 160, 0.3) 50%, transparent 80%);
    }

    .squad-card-info {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 28px;
    }

    .squad-card-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-style: italic;
      font-size: clamp(24px, 3vw, 48px);
      text-transform: uppercase;
      color: #fff;
      line-height: 1;
      margin-bottom: 4px;
    }

    .squad-card-role {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 12px;
    }

    .squad-stats {
      display: flex;
      gap: 16px;
      opacity: 0;
      transform: translateY(12px);
      transition: all 0.3s ease;
    }

    .squad-card:hover .squad-stats {
      opacity: 1;
      transform: translateY(0);
    }

    .squad-stat {
      text-align: left;
    }

    .squad-stat-v {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 22px;
      color: var(--gold);
    }

    .squad-stat-l {
      font-size: 10px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    .squad-num {
      position: absolute;
      top: 20px;
      right: 20px;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 80px;
      color: rgba(253, 185, 19, 0.08);
      line-height: 1;
      user-select: none;
    }

    /* PLAYER SHOWCASE */
    #showcase {
      background: var(--bg2);
    }

    .showcase-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3px;
    }

    .showcase-card {
      position: relative;
      height: 500px;
      overflow: hidden;
      background: var(--bg);
      cursor: none;
    }

    .showcase-bg-name {
      position: absolute;
      bottom: -20px;
      left: -10px;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-style: italic;
      font-size: 160px;
      line-height: 0.8;
      text-transform: uppercase;
      color: rgba(253, 185, 19, 0.06);
      pointer-events: none;
      user-select: none;
    }

    .showcase-card img {
      position: absolute;
      bottom: 0;
      right: 0;
      height: 110%;
      object-fit: contain;
      filter: contrast(1.1);
      transition: transform 0.6s ease;
    }

    .showcase-card:hover img {
      transform: scale(1.04) translateX(-10px);
    }

    .showcase-card-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(6, 8, 16, 0.9) 0%, rgba(6, 8, 16, 0.5) 50%, transparent 80%);
    }

    .showcase-info {
      position: absolute;
      top: 0;
      left: 0;
      bottom: 0;
      padding: 48px;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      z-index: 2;
    }

    .showcase-num {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 13px;
      letter-spacing: 0.3em;
      color: var(--gold);
      margin-bottom: auto;
    }

    .showcase-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-style: italic;
      font-size: 56px;
      line-height: 0.9;
      text-transform: uppercase;
      color: #fff;
      margin-bottom: 6px;
    }

    .showcase-role {
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 24px;
    }

    .showcase-bar {
      width: 48px;
      height: 3px;
      background: var(--gold);
      margin-bottom: 20px;
      clip-path: polygon(4px 0, 100% 0, calc(100% - 4px) 100%, 0 100%);
    }

    .showcase-quote {
      font-size: 14px;
      color: var(--muted);
      font-style: italic;
      max-width: 280px;
      line-height: 1.6;
    }

    /* TIMELINE */
    #timeline {
      background: var(--bg);
      padding-bottom: 80px;
    }

    .timeline-scroll {
      overflow-x: auto;
      overflow-y: visible;
      scrollbar-width: thin;
      scrollbar-color: var(--gold) var(--bg2);
      padding-bottom: 20px;
      cursor: grab;
    }

    .timeline-scroll:active {
      cursor: grabbing;
    }

    .timeline-track {
      display: flex;
      gap: 0;
      min-width: max-content;
      position: relative;
      padding: 20px 0 40px;
    }

    .timeline-track::before {
      content: '';
      position: absolute;
      left: 0;
      right: 0;
      top: 76px;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--border), var(--gold), var(--border), transparent);
    }

    .tl-item {
      width: 220px;
      padding: 0 30px;
      text-align: center;
      position: relative;
      flex-shrink: 0;
    }

    .tl-dot {
      width: 14px;
      height: 14px;
      background: var(--bg2);
      border: 2px solid var(--gold);
      border-radius: 50%;
      margin: 0 auto 20px;
      position: relative;
      z-index: 1;
      transition: background 0.2s;
    }

    .tl-item:hover .tl-dot {
      background: var(--gold);
    }

    .tl-year {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 28px;
      color: var(--gold);
      margin-bottom: 8px;
    }

    .tl-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 16px;
      color: #fff;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 8px;
    }

    .tl-desc {
      font-size: 12px;
      color: var(--muted);
      line-height: 1.5;
    }

    .tl-trophy {
      font-size: 24px;
      margin-bottom: 10px;
    }

    /* FIXTURES */
    #fixtures {
      background: var(--bg2);
    }

    .fixtures-list {
      display: flex;
      flex-direction: column;
      gap: 3px;
    }

    .fixture-row {
      display: grid;
      grid-template-columns: 1fr auto 1fr auto;
      align-items: center;
      background: rgba(255, 255, 255, 0.02);
      padding: 24px 32px;
      border: 1px solid rgba(255, 255, 255, 0.04);
      transition: background 0.2s, border-color 0.2s;
      gap: 20px;
    }

    .fixture-row:hover {
      background: var(--gold-dim);
      border-color: var(--border);
    }

    .fixture-team {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .fixture-team.right {
      justify-content: flex-end;
    }

    .ft-abbr {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 24px;
      color: #fff;
      text-transform: uppercase;
    }

    .ft-name {
      font-size: 13px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    .ft-highlight {
      color: var(--gold) !important;
    }

    .fixture-vs {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 18px;
      letter-spacing: 0.15em;
      color: var(--muted);
      text-align: center;
    }

    .fixture-meta {
      text-align: right;
    }

    .fixture-date {
      font-size: 13px;
      color: var(--muted);
      letter-spacing: 0.1em;
    }

    .fixture-venue {
      font-size: 11px;
      color: rgba(232, 234, 240, 0.3);
      margin-top: 2px;
    }

    .fixture-status {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 4px 10px;
      background: rgba(253, 185, 19, 0.15);
      color: var(--gold);
      border: 1px solid var(--border);
      clip-path: polygon(4px 0, 100% 0, calc(100%-4px) 100%, 0 100%);
    }

    /* TITLES */
    #titles {
      background: var(--bg);
    }

    .titles-grid {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 16px;
      width: 100%;
    }

    @media (max-width: 1200px) {
      .titles-grid {
        grid-template-columns: repeat(4, 1fr) !important;
        gap: 12px;
      }
    }

    @media (max-width: 768px) {
      .titles-grid {
        grid-template-columns: repeat(2, 1fr) !important;
      }
    }

    @media (max-width: 480px) {
      .titles-grid {
        grid-template-columns: 1fr !important;
      }
    }

    .title-block {
      background: var(--bg2);
      border: 1px solid rgba(255, 255, 255, 0.04);
      padding: 48px 32px;
      text-align: center;
      position: relative;
      overflow: hidden;
      transition: all 0.3s;
    }

    .title-block::before {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: var(--gold);
      transform: scaleX(0);
      transition: transform 0.3s;
    }

    .title-block:hover {
      background: rgba(253, 185, 19, 0.06);
    }

    .title-block:hover::before {
      transform: scaleX(1);
    }

    .title-year {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 50px;
      color: var(--gold);
      line-height: 1;
      margin-bottom: 12px;
    }

    .title-trophy {
      font-size: 36px;
      margin-bottom: 16px;
    }

    .title-label {
      font-size: 11px;
      color: var(--muted);
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }

    .title-comp {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 14px;
      color: #fff;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-top: 8px;
    }

    /* FAN ZONE */
    #fanzone {
      background: var(--bg2);
    }

    .fan-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 3px;
    }

    .fan-card {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.04);
      padding: 40px 32px;
      position: relative;
      overflow: hidden;
      transition: all 0.3s;
    }

    .fan-card::after {
      content: '"';
      position: absolute;
      top: -20px;
      right: 20px;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 200px;
      color: rgba(253, 185, 19, 0.04);
      line-height: 1;
      pointer-events: none;
    }

    .fan-card:hover {
      background: var(--gold-dim);
      border-color: var(--border);
    }

    .fan-quote {
      font-size: 15px;
      color: var(--text);
      line-height: 1.7;
      font-style: italic;
      margin-bottom: 24px;
    }

    .fan-author {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .fan-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--gold), var(--blue));
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 16px;
      color: var(--bg);
      flex-shrink: 0;
    }

    .fan-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 16px;
      color: #fff;
      text-transform: uppercase;
    }

    .fan-city {
      font-size: 12px;
      color: var(--muted);
       /* FOOTER REDESIGN */
    /* NEAT & SIMPLE FOOTER */
    footer {
      background: #04060a;
      border-top: 1px solid rgba(253, 185, 19, 0.08);
      padding: 50px 8vw 35px;
      text-align: center;
    }

    .footer-container {
      max-width: 800px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 28px;
    }

    .footer-logo img {
      height: 52px;
      width: auto;
      object-fit: contain;
      filter: drop-shadow(0 0 10px rgba(253, 185, 19, 0.2));
    }

    .footer-tagline {
      font-size: 13.5px;
      color: rgba(232, 234, 240, 0.5);
      max-width: 450px;
      line-height: 1.6;
      margin: -10px auto 0;
    }

    .footer-links {
      display: flex;
      justify-content: center;
      align-items: center;
      flex-wrap: wrap;
      gap: 8px 18px;
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .footer-links li {
      display: flex;
      align-items: center;
    }

    .footer-links li:not(:last-child)::after {
      content: '•';
      color: rgba(253, 185, 19, 0.3);
      margin-left: 18px;
      font-size: 10px;
    }

    .footer-links a {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 14.5px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(232, 234, 240, 0.65);
      text-decoration: none;
      transition: all 0.25s ease;
    }

    .footer-links a:hover {
      color: var(--gold);
      text-shadow: 0 0 8px rgba(253, 185, 19, 0.3);
    }

    .footer-social {
      display: flex;
      justify-content: center;
      gap: 16px;
    }

    .social-btn {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(253, 185, 19, 0.12);
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      font-size: 14px;
      color: rgba(232, 234, 240, 0.6);
      transition: all 0.3s ease;
    }

    .social-btn:hover {
      background: var(--gold);
      border-color: var(--gold);
      color: #04060a;
      transform: translateY(-2px);
      box-shadow: 0 5px 15px rgba(253, 185, 19, 0.25);
    }

    .footer-bottom {
      border-top: 1px solid rgba(255, 255, 255, 0.04);
      width: 100%;
      padding-top: 20px;
      margin-top: 10px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
    }

    .footer-copy {
      font-size: 12.5px;
      color: rgba(232, 234, 240, 0.35);
    }

    .footer-csk {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-style: italic;
      font-size: 13px;
      letter-spacing: 0.15em;
      color: var(--gold);
      text-transform: uppercase;
    }

    @media (max-width: 600px) {
      .footer-bottom {
        flex-direction: column;
        text-align: center;
        gap: 8px;
      }
    }   }

    /* FIXTURE RESULT BADGES */
    .fixture-result-badge {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 12px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 4px 12px;
      clip-path: polygon(4px 0, 100% 0, calc(100% - 4px) 100%, 0 100%);
      display: inline-block;
      margin-bottom: 4px;
    }

    .result-win {
      background: rgba(34, 197, 94, 0.15);
      color: #22c55e;
      border: 1px solid rgba(34, 197, 94, 0.35);
    }

    .result-loss {
      background: rgba(239, 68, 68, 0.12);
      color: #f87171;
      border: 1px solid rgba(239, 68, 68, 0.3);
    }

    .result-upcoming {
      background: rgba(253, 185, 19, 0.15);
      color: var(--gold);
      border: 1px solid var(--border);
    }

    /* SEASON STRIP */
    .fixture-season-strip {
      display: flex;
      align-items: center;
      gap: 0;
      background: var(--bg2);
      border: 1px solid var(--border);
      margin-bottom: 24px;
      padding: 0 32px;
    }

    .fss-item {
      padding: 20px 28px;
      text-align: center;
    }

    .fss-val {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 40px;
      color: var(--gold);
      line-height: 1;
    }

    .fss-win {
      color: #22c55e;
    }

    .fss-loss {
      color: #f87171;
    }

    .fss-label {
      font-size: 11px;
      color: var(--muted);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-top: 2px;
    }

    .fss-divider {
      width: 1px;
      height: 48px;
      background: var(--border);
      flex-shrink: 0;
    }

    .fss-spacer {
      flex: 1;
    }

    .fss-season-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 14px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
    }

    @media (max-width: 700px) {
      .fixture-season-strip {
        flex-wrap: wrap;
        padding: 16px;
        gap: 0;
      }

      .fss-spacer {
        display: none;
      }

      .fss-season-label {
        width: 100%;
        text-align: center;
        padding: 12px 0 4px;
        font-size: 12px;
      }
    }



    /* ── Filter buttons ──────────────────────────────────────────────── */
    .sq26-filters {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 8px;
    }

    .sq26-filter-btn {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 13px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      cursor: none;
      padding: 8px 18px;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
      color: var(--muted);
      transition: all 0.2s;
      clip-path: polygon(6px 0, 100% 0, calc(100% - 6px) 100%, 0 100%);
    }

    .sq26-filter-btn:hover {
      background: var(--gold-dim);
      color: var(--gold);
      border-color: var(--border);
    }

    .sq26-filter-btn.active {
      background: var(--gold);
      color: var(--bg);
      border-color: var(--gold);
    }

    .sq26-filter-count {
      font-size: 11px;
      opacity: 0.7;
    }

    /* ── Card avatar redesign ────────────────────────────────────────── */
    .sq26-av {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      position: absolute;
      inset: 0;
      flex-direction: column;
      gap: 0;
      overflow: hidden;
    }

    .sq26-av-jersey {
      position: absolute;
      pointer-events: none;
      user-select: none;
      animation: none;
    }

    .sq26-av-initials {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 28px;
      position: relative;
      z-index: 1;
      letter-spacing: -1px;
      transition: transform 0.3s;
    }

    .squad2026-card:hover .sq26-av-initials {
      transform: scale(1.08);
    }

    .sq26-av-icon {
      font-size: 18px;
      margin-top: 10px;
      position: relative;
      z-index: 1;
      opacity: 0.7;
    }

    /* ── Role type tag ───────────────────────────────────────────────── */
    .sq26-type-tag {
      position: absolute;
      top: 12px;
      left: 12px;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 3px 10px;
      border: 1px solid;
      z-index: 5;
      clip-path: polygon(4px 0, 100% 0, calc(100% - 4px) 100%, 0 100%);
    }

    /* ── Filtered-out cards ──────────────────────────────────────────── */
    .squad2026-card.sq26-hidden {
      display: none;
    }

    /* ═══ SQUAD 2026 CAROUSEL ══════════════════════════════ */
    .sq26-carousel-outer {
      overflow: hidden;
      position: relative;
      padding: 0 8vw;
    }

    .sq26-track {
      display: flex;
      gap: 16px;
      transition: transform 0.45s cubic-bezier(0.25, 1, 0.5, 1);
      cursor: grab;
      user-select: none;
      will-change: transform;
    }

    .sq26-track:active {
      cursor: grabbing;
    }

    .squad2026-card {
      flex: 0 0 220px;
      width: 220px;
      background: var(--bg);
      border: 1px solid rgba(255, 255, 255, 0.05);
      transition: all 0.3s;
      position: relative;
      overflow: hidden;
    }

    .squad2026-card:hover {
      border-color: var(--border);
      transform: translateY(-6px);
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4), 0 0 20px rgba(253, 185, 19, 0.08);
    }

    .sq26-img-wrap {
      height: 240px;
      width: 100%;
      overflow: hidden;
      position: relative;
      background: var(--bg2);
    }

    /* Gold bottom gradient on every card image */
    .sq26-img-wrap::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 60px;
      background: linear-gradient(to top, var(--bg2) 0%, transparent 100%);
      z-index: 2;
      pointer-events: none;
    }

    .sq26-initials-fb {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      position: absolute;
      inset: 0;
      flex-direction: column;
      gap: 4px;
    }

    .sq26-photo {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top center;
      display: block;
      position: absolute;
      inset: 0;
      filter: grayscale(0.1) contrast(1.1);
      transition: transform 0.4s ease, filter 0.3s;
      z-index: 1;
    }

    .squad2026-card:hover .sq26-photo {
      transform: scale(1.07);
      filter: grayscale(0) contrast(1.15);
    }

    /* Gold shimmer on hover */
    .sq26-shine {
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: linear-gradient(120deg, transparent 30%, rgba(253, 185, 19, 0.06) 50%, transparent 70%);
      opacity: 0;
      transition: opacity 0.4s;
      z-index: 3;
    }

    .squad2026-card:hover .sq26-shine {
      opacity: 1;
    }

    .sq26-info {
      padding: 16px;
      position: relative;
    }

    .sq26-num {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 11px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      margin-bottom: 4px;
    }

    .sq26-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 18px;
      color: #fff;
      text-transform: uppercase;
      line-height: 1.1;
      margin-bottom: 4px;
    }

    .sq26-role {
      font-size: 11px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      margin-bottom: 8px;
    }

    .sq26-nat {
      font-size: 16px;
    }

    /* Hover overlay on card */
    .squad2026-card::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(6, 8, 16, 0.8) 0%, transparent 60%);
      pointer-events: none;
    }

    /* Controls */
    .sq26-carousel-controls {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .sq26-btn {
      width: 44px;
      height: 44px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid var(--border);
      color: var(--gold);
      font-size: 18px;
      cursor: none;
      transition: all 0.2s;
      clip-path: polygon(6px 0, 100% 0, calc(100% - 6px) 100%, 0 100%);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .sq26-btn:hover {
      background: var(--gold-dim);
    }

    .sq26-btn:disabled {
      opacity: 0.3;
      pointer-events: none;
    }

    .sq26-dots {
      display: flex;
      gap: 6px;
      align-items: center;
    }

    .sq26-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: rgba(253, 185, 19, 0.25);
      transition: all 0.25s;
      cursor: pointer;
    }

    .sq26-dot.active {
      background: var(--gold);
      width: 18px;
      border-radius: 3px;
    }

    .sq26-hint {
      text-align: center;
      font-size: 12px;
      color: rgba(232, 234, 240, 0.25);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 16px 0 0;
    }

    @media (max-width: 700px) {
      .squad2026-card {
        flex: 0 0 160px;
        width: 160px;
      }

      .sq26-img-wrap {
        height: 170px;
      }
    }

    /* SCROLL REVEAL */
    .reveal {
      opacity: 0;
      transform: translateY(40px);
      transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .reveal-delay-1 {
      transition-delay: 0.1s;
    }

    .reveal-delay-2 {
      transition-delay: 0.2s;
    }

    .reveal-delay-3 {
      transition-delay: 0.3s;
    }

    .reveal-delay-4 {
      transition-delay: 0.4s;
    }

    /* GOLD LINE */
    .gold-line {
      width: 60px;
      height: 3px;
      background: var(--gold);
      margin: 20px 0 40px;
      clip-path: polygon(4px 0, 100% 0, calc(100% - 4px) 100%, 0 100%);
    }

    @media (max-width: 900px) {
      nav {
        padding: 0 24px;
      }

      .nav-links {
        display: none;
      }

      section {
        padding: 40px 5vw 28px;
      }

      .legacy-layout {
        grid-template-columns: 1fr;
        gap: 40px;
      }

      .squad-grid {
        grid-template-columns: 1fr 1fr;
        height: auto;
      }

      .squad-card:first-child {
        grid-row: auto;
        grid-column: 1 / 3;
        height: 400px;
      }

      .squad-card {
        height: 260px;
      }

      .showcase-grid {
        grid-template-columns: 1fr;
      }

      .titles-grid {
        grid-template-columns: repeat(3, 1fr);
      }

      .fan-grid {
        grid-template-columns: 1fr;
      }

      .footer-top {
        grid-template-columns: 1fr 1fr;
        gap: 40px;
      }
    }

    /* ═══════════════════════════════════════════════════
   PLAYERS ARCHIVE (2008–2026)
═══════════════════════════════════════════════════ */
    #players-archive {
      background: var(--bg);
    }

    .archive-layout {
      display: grid;
      grid-template-columns: 240px 1fr;
      gap: 0;
      min-height: 600px;
    }

    /* Sticky year-nav sidebar */
    .archive-nav {
      position: sticky;
      top: 72px;
      height: calc(100vh - 72px);
      overflow-y: auto;
      padding: 24px 0;
      border-right: 1px solid var(--border);
      scrollbar-width: thin;
      scrollbar-color: var(--gold) transparent;
      flex-shrink: 0;
    }

    .archive-nav-year {
      display: block;
      padding: 8px 24px;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 16px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      cursor: pointer;
      transition: all 0.2s;
      border-left: 3px solid transparent;
      position: relative;
    }

    .archive-nav-year:hover,
    .archive-nav-year.active {
      color: var(--gold);
      border-left-color: var(--gold);
    }

    .archive-nav-year .champ-dot {
      display: inline-block;
      width: 8px;
      height: 8px;
      background: var(--gold);
      border-radius: 50%;
      margin-left: 8px;
      vertical-align: middle;
    }

    .archive-nav-year.suspended {
      color: rgba(255, 80, 80, 0.5);
    }

    .archive-nav-year.suspended:hover {
      color: rgba(255, 80, 80, 0.9);
      border-left-color: rgba(255, 80, 80, 0.7);
    }

    /* Main content */
    .archive-content {
      padding: 0 48px;
    }

    /* Era banners */
    .era-banner {
      background: linear-gradient(135deg, var(--bg2) 0%, rgba(0, 71, 160, 0.15) 100%);
      border: 1px solid var(--border);
      padding: 32px 40px;
      margin-bottom: 48px;
      margin-top: 60px;
      position: relative;
      overflow: hidden;
    }

    .era-banner:first-child {
      margin-top: 0;
    }

    .era-banner::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 4px;
      background: var(--gold);
      clip-path: polygon(0 0, 100% 4px, 100% calc(100% - 4px), 0 100%);
    }

    .era-banner-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-style: italic;
      font-size: 40px;
      color: #fff;
      text-transform: uppercase;
      margin-bottom: 4px;
    }

    .era-banner-subtitle {
      font-size: 13px;
      color: var(--muted);
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }

    .era-trophies {
      margin-top: 12px;
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .era-trophy-chip {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 12px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 4px 12px;
      background: rgba(253, 185, 19, 0.15);
      border: 1px solid var(--border);
      color: var(--gold);
      clip-path: polygon(4px 0, 100% 0, calc(100% - 4px) 100%, 0 100%);
    }

    /* Year section */
    .year-section {
      margin-bottom: 56px;
      scroll-margin-top: 88px;
    }

    .year-header {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 24px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--border);
      cursor: pointer;
      user-select: none;
    }

    .year-header-num {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-style: italic;
      font-size: 56px;
      color: var(--gold);
      line-height: 1;
    }

    .year-header-info {
      flex: 1;
    }

    .year-header-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 14px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .year-header-count {
      font-size: 12px;
      color: rgba(232, 234, 240, 0.4);
      margin-top: 2px;
    }

    .champ-badge {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 12px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 6px 14px;
      background: linear-gradient(135deg, var(--gold), #ffb700);
      color: var(--bg);
      clip-path: polygon(6px 0, 100% 0, calc(100% - 6px) 100%, 0 100%);
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .year-toggle {
      color: var(--muted);
      font-size: 18px;
      transition: transform 0.3s;
      flex-shrink: 0;
    }

    .year-section.collapsed .year-toggle {
      transform: rotate(-90deg);
    }

    /* Player grid */
    .player-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 3px;
      overflow: hidden;
      max-height: 9999px;
      transition: max-height 0.5s ease;
    }

    .year-section.collapsed .player-grid {
      max-height: 0;
    }

    .player-card {
      background: var(--bg2);
      border: 1px solid rgba(255, 255, 255, 0.04);
      padding: 18px 16px;
      cursor: none;
      transition: all 0.25s;
      clip-path: polygon(0 0, calc(100% - 0px) 0, 100% 0, 100% 100%, 0 100%);
    }

    .player-card:hover {
      background: var(--gold-dim);
      border-color: var(--border);
      transform: translateY(-2px);
    }

    .player-card-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 17px;
      color: #fff;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      line-height: 1.2;
    }

    .player-card-role {
      font-size: 11px;
      color: var(--muted);
      margin-top: 4px;
      letter-spacing: 0.1em;
    }

    .player-num {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 32px;
      color: rgba(253, 185, 19, 0.12);
      line-height: 1;
    }

    /* Suspension card */
    .suspension-card {
      background: rgba(255, 50, 50, 0.06);
      border: 1px solid rgba(255, 50, 50, 0.2);
      padding: 40px 32px;
      text-align: center;
    }

    .suspension-card-icon {
      font-size: 40px;
      margin-bottom: 16px;
    }

    .suspension-card-text {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 22px;
      color: rgba(255, 100, 100, 0.8);
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    /* Search bar */
    .archive-search-wrap {
      margin-bottom: 20px;
    }

    .archive-search {
      width: 100%;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid var(--border);
      color: var(--text);
      font-family: 'Poppins', sans-serif;
      font-size: 15px;
      padding: 14px 20px;
      outline: none;
      transition: border-color 0.2s;
      clip-path: polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%);
    }

    .archive-search:focus {
      border-color: var(--gold);
    }

    .archive-search::placeholder {
      color: var(--muted);
    }

    /* ═══════════════════════════════════════════════════
   ENHANCED ACHIEVEMENTS / TROPHY SECTION
═══════════════════════════════════════════════════ */
    .trophy-stats-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 3px;
      margin-bottom: 60px;
    }

    .trophy-stat-card {
      background: var(--bg2);
      border: 1px solid var(--border);
      padding: 40px 32px;
      text-align: center;
      position: relative;
      overflow: hidden;
      transition: all 0.3s;
    }

    .trophy-stat-card:hover {
      background: var(--gold-dim);
    }

    .trophy-stat-card::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: var(--gold);
      transform: scaleX(0);
      transition: transform 0.3s;
    }

    .trophy-stat-card:hover::after {
      transform: scaleX(1);
    }

    .trophy-stat-val {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 80px;
      color: var(--gold);
      line-height: 1;
      margin-bottom: 8px;
    }

    .trophy-stat-label {
      font-size: 13px;
      color: var(--muted);
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }

    .trophy-stat-icon {
      font-size: 32px;
      margin-bottom: 12px;
    }

    /* IPL + CLT20 title grids */
    .trophy-section-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 22px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .trophy-section-title::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    .ipl-titles-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 3px;
      margin-bottom: 48px;
    }

    .clt20-titles-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 3px;
      margin-bottom: 48px;
    }

    .trophy-title-card {
      background: var(--bg2);
      border: 1px solid rgba(255, 255, 255, 0.04);
      padding: 36px 24px;
      text-align: center;
      transition: all 0.3s;
      position: relative;
      overflow: hidden;
    }

    .trophy-title-card:hover {
      background: var(--gold-dim);
      border-color: var(--border);
    }

    .trophy-title-card .tt-trophy {
      font-size: 36px;
      margin-bottom: 12px;
    }

    .trophy-title-card .tt-year {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 52px;
      color: var(--gold);
      line-height: 1;
      margin-bottom: 8px;
    }

    .trophy-title-card .tt-comp {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 14px;
      color: #fff;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .trophy-title-card .tt-note {
      font-size: 11px;
      color: var(--muted);
      margin-top: 6px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .tt-back-to-back {
      position: absolute;
      top: 0;
      right: 0;
      background: var(--gold);
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--bg);
      padding: 4px 10px;
      clip-path: polygon(8px 0, 100% 0, 100% 100%, 0 100%);
    }

    /* ═══════════════════════════════════════════════════
   CSK LEGENDS
═══════════════════════════════════════════════════ */
    #legends {
      background: var(--bg2);
    }

    .legends-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 3px;
    }

    .legend-card {
      position: relative;
      overflow: hidden;
      background: var(--bg);
      height: 360px;
      cursor: none;
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 16px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
      transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), border-color 0.4s, box-shadow 0.4s;
    }

    .legend-card:hover {
      transform: translateY(-8px) scale(1.02);
      border-color: rgba(253, 185, 19, 0.25);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5), 0 0 20px rgba(253, 185, 19, 0.1);
    }

    .legend-card-bg {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, var(--bg) 0%, rgba(0, 71, 160, 0.18) 100%);
    }

    .legend-spotlight {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 60% 80% at 50% 50%, rgba(253, 185, 19, 0) 0%, transparent 70%);
      transition: background 0.4s;
    }

    .legend-card:hover .legend-spotlight {
      background: radial-gradient(ellipse 60% 80% at 50% 30%, rgba(253, 185, 19, 0.1) 0%, transparent 70%);
    }

    .legend-bg-num {
      position: absolute;
      top: 50%;
      right: -10px;
      transform: translateY(-50%);
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 99px;
      color: rgba(253, 185, 19, 0.04);
      line-height: 1;
      user-select: none;
      pointer-events: none;
      transition: transform 0.4s ease, color 0.4s ease;
    }

    .legend-card:hover .legend-bg-num {
      transform: translateY(-50%) scale(1.12);
      color: rgba(253, 185, 19, 0.08);
    }

    .legend-card-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(6, 8, 16, 0.95) 0%, rgba(6, 8, 16, 0.4) 50%, transparent 80%);
    }

    .legend-card-info {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 24px 20px;
      z-index: 2;
    }

    .legend-card-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-style: italic;
      font-size: 24px;
      color: #fff;
      text-transform: uppercase;
      line-height: 1;
      margin-bottom: 4px;
      letter-spacing: 0.02em;
      text-shadow: 0 2px 4px rgba(0, 0, 0, 0.4);
    }

    .legend-card-role {
      font-size: 9px;
      color: var(--gold);
      font-weight: 700;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      margin-bottom: 12px;
      opacity: 0.9;
    }

    .legend-stats {
      display: flex;
      gap: 16px;
      opacity: 0;
      transform: translateY(10px);
      transition: all 0.3s;
    }

    .legend-card:hover .legend-stats {
      opacity: 1;
      transform: translateY(0);
    }

    .legend-stat-v {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 20px;
      color: #fff;
      text-shadow: 0 0 10px rgba(253, 185, 19, 0.25);
    }

    .legend-stat-l {
      font-size: 8px;
      color: var(--gold);
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }

    .legend-glow {
      position: absolute;
      inset: 0;
      opacity: 0;
      background: radial-gradient(ellipse at 50% 100%, rgba(253, 185, 19, 0.08) 0%, transparent 70%);
      transition: opacity 0.4s;
    }

    .legend-card:hover .legend-glow {
      opacity: 1;
    }

    /* ═══════════════════════════════════════════════════
   EXTENDED INTERACTIVE TIMELINE
═══════════════════════════════════════════════════ */
    .xtl-scroll {
      overflow-x: auto;
      overflow-y: visible;
      padding-bottom: 24px;
      scrollbar-width: thin;
      scrollbar-color: var(--gold) transparent;
      cursor: grab;
    }

    .xtl-scroll:active {
      cursor: grabbing;
    }

    .xtl-track {
      display: flex;
      min-width: max-content;
      position: relative;
      padding: 60px 48px 20px;
    }

    .xtl-track::before {
      content: '';
      position: absolute;
      left: 48px;
      right: 48px;
      top: 88px;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--border), var(--gold), var(--gold), var(--border), transparent);
    }

    .xtl-item {
      width: 200px;
      text-align: center;
      flex-shrink: 0;
      position: relative;
      padding: 0 16px;
    }

    .xtl-dot-wrap {
      position: relative;
      z-index: 2;
      margin-bottom: 16px;
    }

    .xtl-dot {
      width: 16px;
      height: 16px;
      margin: 0 auto;
      background: var(--bg2);
      border: 2px solid var(--border);
      border-radius: 50%;
      transition: all 0.25s;
    }

    .xtl-item:hover .xtl-dot {
      background: var(--gold);
      border-color: var(--gold);
      box-shadow: 0 0 16px rgba(253, 185, 19, 0.5);
    }

    .xtl-item.champion .xtl-dot {
      border-color: var(--gold);
      background: rgba(253, 185, 19, 0.2);
    }

    .xtl-item.suspended .xtl-dot {
      border-color: rgba(255, 80, 80, 0.5);
      background: rgba(255, 50, 50, 0.1);
    }

    .xtl-trophy-icon {
      font-size: 22px;
      margin-bottom: 8px;
    }

    .xtl-year {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 30px;
      line-height: 1;
      margin-bottom: 6px;
    }

    .xtl-item.champion .xtl-year {
      color: var(--gold);
    }

    .xtl-item.suspended .xtl-year {
      color: rgba(255, 80, 80, 0.7);
    }

    .xtl-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 14px;
      color: #fff;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 6px;
    }

    .xtl-desc {
      font-size: 11px;
      color: var(--muted);
      line-height: 1.5;
    }

    .xtl-captain {
      font-size: 11px;
      color: var(--gold);
      margin-top: 6px;
      font-style: italic;
    }

    @media (max-width: 900px) {
      .archive-layout {
        grid-template-columns: 1fr;
      }

      .archive-nav {
        position: static;
        height: auto;
        overflow: visible;
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        padding: 0 0 20px;
      }

      .archive-content {
        padding: 0 16px;
      }

      .trophy-stats-row {
        grid-template-columns: 1fr 1fr;
      }

      .ipl-titles-grid {
        grid-template-columns: repeat(3, 1fr);
      }

      .legends-grid {
        grid-template-columns: 1fr;
      }

      .legend-card {
        height: 280px;
      }
    }


    /* ═══ FIXTURES BENTO CAROUSEL ════════════════════════════════ */
    .fxt-summary {
      display: flex;
      align-items: center;
      gap: 0;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 14px 28px;
      width: fit-content;
      margin-bottom: 0;
      clip-path: polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%);
    }

    .fxt-sum-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 0 20px;
    }

    .fxt-sum-v {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 28px;
      color: var(--text);
      line-height: 1;
    }

    .fxt-sum-l {
      font-size: 11px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: .12em;
      margin-top: 3px;
    }

    .fxt-sum-sep {
      width: 1px;
      height: 36px;
      background: var(--border);
    }

    .fxt-carousel-outer {
      overflow: hidden;
      padding: 0 8vw 8px;
    }

    .fxt-track {
      display: flex;
      gap: 16px;
      cursor: grab;
      user-select: none;
      transition: transform 0.4s cubic-bezier(.25, .8, .25, 1);
      padding-bottom: 12px;
    }

    .fxt-track:active {
      cursor: grabbing;
    }

    .fxt-card {
      flex: 0 0 180px;
      width: 180px;
      aspect-ratio: 1/1;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid var(--border);
      border-radius: 16px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4px;
      padding: 16px;
      position: relative;
      overflow: hidden;
      transition: transform .25s, border-color .25s, box-shadow .25s;
      cursor: default;
    }

    .fxt-card:hover {
      transform: translateY(-4px);
    }

    .fxt-card--win {
      border-color: rgba(74, 222, 128, .25);
    }

    .fxt-card--win:hover {
      border-color: rgba(74, 222, 128, .5);
      box-shadow: 0 8px 32px rgba(74, 222, 128, .15);
    }

    .fxt-card--loss {
      border-color: rgba(248, 113, 113, .2);
    }

    .fxt-card--loss:hover {
      border-color: rgba(248, 113, 113, .4);
      box-shadow: 0 8px 32px rgba(248, 113, 113, .12);
    }

    .fxt-card-date {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 13px;
      font-weight: 700;
      color: var(--muted);
      letter-spacing: .1em;
      text-transform: uppercase;
    }

    .fxt-card-vs {
      font-size: 10px;
      color: var(--muted);
      opacity: .5;
    }

    .fxt-card-opp {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 36px;
      line-height: 1;
      color: var(--text);
    }

    .fxt-card-venue {
      font-size: 11px;
      color: var(--muted);
    }

    .fxt-card-result {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 22px;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-top: 4px;
    }

    .fxt-win {
      background: rgba(74, 222, 128, .15);
      color: #4ade80;
      border: 2px solid rgba(74, 222, 128, .4);
    }

    .fxt-loss {
      background: rgba(248, 113, 113, .12);
      color: #f87171;
      border: 2px solid rgba(248, 113, 113, .3);
    }

    .fxt-card-margin {
      font-size: 10px;
      color: var(--muted);
      text-align: center;
      max-width: 140px;
      line-height: 1.3;
    }

    .fxt-card-glow {
      position: absolute;
      inset: 0;
      pointer-events: none;
      border-radius: inherit;
    }

    .fxt-card--win .fxt-card-glow {
      background: radial-gradient(circle at 50% 100%, rgba(74, 222, 128, .05) 0%, transparent 70%);
    }

    .fxt-card--loss .fxt-card-glow {
      background: radial-gradient(circle at 50% 100%, rgba(248, 113, 113, .04) 0%, transparent 70%);
    }

    .fxt-btn {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 18px;
      background: rgba(255, 255, 255, .04);
      border: 1px solid var(--border);
      color: var(--muted);
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: none;
      transition: all .2s;
      clip-path: polygon(6px 0, 100% 0, calc(100% - 6px) 100%, 0 100%);
    }

    .fxt-btn:hover {
      background: var(--gold);
      color: var(--bg);
      border-color: var(--gold);
    }

    .fxt-carousel-controls {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .fxt-dots {
      display: flex;
      gap: 6px;
      align-items: center;
    }

    .fxt-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--border);
      cursor: none;
      transition: .2s;
    }

    .fxt-dot.active {
      background: var(--gold);
      width: 18px;
      border-radius: 3px;
    }

    .fxt-hint {
      text-align: center;
      font-size: 12px;
      color: var(--muted);
      margin-top: 20px;
      opacity: .5;
    }

    @media(max-width:600px) {
      .fxt-card {
        flex: 0 0 155px;
        width: 155px;
      }
    }

    /* ═══ FAIR PLAY AWARDS CAROUSEL ════════════════════════════════ */
    .fp-carousel-outer {
      padding: 0 8vw 8px;
    }

    .fp-track {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 16px;
      width: 100%;
    }

    .fp-card {
      aspect-ratio: 1/1;
      background: linear-gradient(135deg, rgba(253, 185, 19, .05), rgba(253, 185, 19, .12));
      border: 1px solid rgba(253, 185, 19, .2);
      border-radius: 16px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 6px;
      padding: 16px;
      text-align: center;
      transition: transform .25s, border-color .25s, box-shadow .25s;
      position: relative;
      overflow: hidden;
    }

    .fp-card::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: inherit;
      background: radial-gradient(circle at 50% 0%, rgba(253, 185, 19, .08) 0%, transparent 65%);
    }

    .fp-card:hover {
      transform: translateY(-5px);
      border-color: rgba(253, 185, 19, .5);
      box-shadow: 0 12px 40px rgba(253, 185, 19, .15);
    }

    .fp-medal {
      font-size: 32px;
      line-height: 1;
    }

    .fp-year {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 30px;
      color: var(--gold);
      line-height: 1;
    }

    .fp-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 11px;
      color: var(--text);
      letter-spacing: .06em;
    }

    .fp-sublabel {
      font-size: 9px;
      color: var(--muted);
      letter-spacing: .08em;
      text-transform: uppercase;
    }

    .fp-btn, .fp-carousel-controls, .fp-hint {
      display: none !important;
    }

    @media (max-width: 1200px) {
      .fp-track {
        grid-template-columns: repeat(4, 1fr) !important;
      }
    }

    @media (max-width: 768px) {
      .fp-track {
        grid-template-columns: repeat(2, 1fr) !important;
      }
    }

    @media (max-width: 480px) {
      .fp-track {
        grid-template-columns: 1fr !important;
      }
    }

    /* ═══ LEGENDS CAROUSEL ════════════════════════════════════════ */
    .leg-carousel-outer {
      padding: 0 8vw 8px;
    }

    .leg-track {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 16px;
      width: 100%;
    }

    .leg-track .legend-card {
      width: 100%;
      min-width: 0;
      height: 330px;
    }

    .leg-btn, .leg-carousel-controls, .leg-hint {
      display: none !important;
    }

    @media (max-width: 1200px) {
      .leg-track {
        grid-template-columns: repeat(4, 1fr) !important;
      }
    }

    @media (max-width: 768px) {
      .leg-track {
        grid-template-columns: repeat(2, 1fr) !important;
      }
    }

    @media (max-width: 480px) {
      .leg-track {
        grid-template-columns: 1fr !important;
      }
    }
      background: var(--gold);
      width: 18px;
      border-radius: 3px;
    }

    .leg-hint {
      text-align: center;
      font-size: 12px;
      color: var(--muted);
      margin-top: 20px;
      opacity: .5;
    }

    @media(max-width:600px) {
      .leg-track .legend-card {
        flex: 0 0 280px;
        min-width: 280px;
      }
    }

    /* ═══ TITLES GRID (7 crowns) ══════════════════════════════════ */
    .title-block .title-trophy {
      font-size: 32px;
      line-height: 1;
      margin-bottom: 8px;
    }


    /* ═══ SEASON CHRONICLE ════════════════════════════════════════════ */
    .chr-scroll {
      overflow-x: auto;
      padding: 0 8vw 20px;
      scrollbar-width: none;
    }

    .chr-scroll::-webkit-scrollbar {
      display: none;
    }

    .chr-track {
      display: flex;
      gap: 20px;
      padding-bottom: 8px;
      min-width: max-content;
      cursor: grab;
    }

    .chr-track:active {
      cursor: grabbing;
    }

    .chr-card {
      flex: 0 0 220px;
      width: 220px;
      border-radius: 16px;
      padding: 24px 20px;
      border: 1px solid var(--border);
      background: rgba(255, 255, 255, .03);
      display: flex;
      flex-direction: column;
      gap: 8px;
      transition: transform .25s, box-shadow .25s;
      position: relative;
      overflow: hidden;
    }

    .chr-card::before {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 3px;
      border-radius: 0 0 16px 16px;
    }

    .chr-card:hover {
      transform: translateY(-4px);
    }

    .chr-win {
      border-color: rgba(253, 185, 19, .3);
    }

    .chr-win::before {
      background: var(--gold);
    }

    .chr-win:hover {
      box-shadow: 0 12px 40px rgba(253, 185, 19, .15);
    }

    .chr-silver {
      border-color: rgba(192, 192, 192, .25);
    }

    .chr-silver::before {
      background: #c0c0c0;
    }

    .chr-silver:hover {
      box-shadow: 0 12px 40px rgba(192, 192, 192, .1);
    }

    .chr-semi {
      border-color: rgba(96, 165, 250, .2);
    }

    .chr-semi::before {
      background: #60a5fa;
    }

    .chr-semi:hover {
      box-shadow: 0 12px 40px rgba(96, 165, 250, .1);
    }

    .chr-ban {
      border-color: rgba(248, 113, 113, .2);
    }

    .chr-ban::before {
      background: #f87171;
    }

    .chr-ban:hover {
      box-shadow: 0 12px 40px rgba(248, 113, 113, .1);
    }

    .chr-clt {
      border-color: rgba(167, 139, 250, .25);
    }

    .chr-clt::before {
      background: #a78bfa;
    }

    .chr-clt:hover {
      box-shadow: 0 12px 40px rgba(167, 139, 250, .1);
    }

    .chr-now {
      border-color: rgba(253, 185, 19, .5);
      background: rgba(253, 185, 19, .04);
    }

    .chr-now::before {
      background: linear-gradient(90deg, var(--gold), #fff600);
    }

    .chr-now:hover {
      box-shadow: 0 12px 40px rgba(253, 185, 19, .2);
    }

    .chr-icon {
      font-size: 28px;
      line-height: 1;
    }

    .chr-year {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 40px;
      line-height: 1;
      color: var(--text);
    }

    .chr-badge {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 10px;
      letter-spacing: .18em;
      text-transform: uppercase;
      padding: 3px 10px;
      border-radius: 20px;
      width: fit-content;
    }

    .chr-badge--win {
      background: rgba(253, 185, 19, .15);
      color: var(--gold);
    }

    .chr-badge--silver {
      background: rgba(192, 192, 192, .12);
      color: #c0c0c0;
    }

    .chr-badge--semi {
      background: rgba(96, 165, 250, .12);
      color: #60a5fa;
    }

    .chr-badge--ban {
      background: rgba(248, 113, 113, .12);
      color: #f87171;
    }

    .chr-badge--clt {
      background: rgba(167, 139, 250, .15);
      color: #a78bfa;
    }

    .chr-badge--now {
      background: rgba(253, 185, 19, .2);
      color: var(--gold);
    }

    .chr-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 17px;
      color: var(--text);
      line-height: 1.2;
    }

    .chr-desc {
      font-size: 12px;
      color: var(--muted);
      line-height: 1.55;
    }

    /* ═══ YEAR-WISE SQUAD ════════════════════════════════════════════ */
    .yw-controls {
      display: flex;
      flex-direction: column;
      gap: 6px;
      align-items: flex-end;
    }

    .yw-label {
      font-size: 11px;
      color: var(--muted);
      letter-spacing: .12em;
      text-transform: uppercase;
    }

    .yw-select-wrap {
      position: relative;
    }

    .yw-select {
      appearance: none;
      -webkit-appearance: none;
      background: rgba(255, 255, 255, .05);
      border: 1px solid var(--border);
      color: var(--text);
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 18px;
      padding: 10px 44px 10px 18px;
      border-radius: 8px;
      cursor: pointer;
      transition: border-color .2s, background .2s;
      min-width: 180px;
    }

    .yw-select:hover,
    .yw-select:focus {
      border-color: var(--gold);
      outline: none;
      background: rgba(253, 185, 19, .06);
    }

    .yw-select option {
      background: #0d1117;
      color: var(--text);
    }

    .yw-select-icon {
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--gold);
      font-size: 16px;
      pointer-events: none;
    }

    .yw-season-strip {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 0;
      padding: 12px 0;
      border-bottom: 1px solid var(--border);
    }

    .yw-season-year {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 52px;
      color: var(--gold);
      line-height: 1;
      transition: all .3s;
    }

    .yw-season-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 15px;
      color: var(--muted);
      letter-spacing: .1em;
      text-transform: uppercase;
    }

    .yw-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 16px;
      padding: 16px 8vw 0;
      transition: opacity .3s;
    }

    .yw-player-card {
      width: 100%;
      flex: unset;
    }

    .yw-player-card {
      flex: 0 0 180px;
      width: 180px;
      background: rgba(255, 255, 255, .03);
      border: 1px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
      transition: transform .25s, border-color .25s, box-shadow .25s;
      position: relative;
    }

    .yw-player-card:hover {
      transform: translateY(-4px);
    }

    .yw-card-top {
      height: 130px;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .yw-card-av {
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }

    .yw-card-jersey {
      position: absolute;
      bottom: -6px;
      right: -4px;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-style: italic;
      font-size: 72px;
      line-height: 1;
      opacity: .25;
      user-select: none;
    }

    .yw-card-initials {
      width: 60px;
      height: 60px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 22px;
      background: rgba(6, 8, 16, .6);
      border: 2px solid;
      position: relative;
      z-index: 1;
    }

    .yw-card-icon {
      font-size: 16px;
      margin-top: 8px;
      position: relative;
      z-index: 1;
      opacity: .7;
    }

    .yw-card-photo {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .yw-type-tag {
      position: absolute;
      top: 8px;
      left: 8px;
      z-index: 2;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 9px;
      letter-spacing: .18em;
      text-transform: uppercase;
      padding: 2px 8px;
      border: 1px solid;
      border-radius: 0;
      clip-path: polygon(4px 0, 100% 0, calc(100% - 4px) 100%, 0 100%);
    }

    .yw-card-info {
      padding: 12px 14px;
    }

    .yw-card-num {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 12px;
    }

    .yw-card-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 15px;
      color: var(--text);
      line-height: 1.2;
      margin-top: 2px;
    }

    .yw-card-role {
      font-size: 11px;
      color: var(--muted);
      margin-top: 3px;
    }

    @media(max-width:600px) {
      .yw-player-card {
        flex: 0 0 155px;
        width: 155px;
      }

      .yw-season-year {
        font-size: 36px;
      }
    }


    /* ═══ HAMBURGER MENU ══════════════════════════════════════════ */
    .nav-hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 8px;
      z-index: 200;
    }

    .nav-hamburger span {
      display: block;
      width: 26px;
      height: 2px;
      background: var(--text);
      border-radius: 2px;
      transition: .3s;
    }

    .nav-hamburger.active span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .nav-hamburger.active span:nth-child(2) {
      opacity: 0;
    }

    .nav-hamburger.active span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }

    .nav-highlight {
      color: var(--gold) !important;
    }

    @media(max-width:900px) {
      .nav-hamburger {
        display: flex;
      }

      .nav-links {
        position: fixed;
        top: 0;
        right: -100%;
        width: min(320px, 80vw);
        height: 100vh;
        background: rgba(6, 8, 16, .98);
        backdrop-filter: blur(20px);
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 32px;
        transition: right .4s cubic-bezier(.25, .8, .25, 1);
        border-left: 1px solid var(--border);
        z-index: 150;
        list-style: none;
        padding: 0;
        margin: 0;
      }

      .nav-links.open {
        right: 0;
      }

      .nav-links a {
        font-size: 20px;
      }

      .nav-right .live-badge {
        display: none;
      }
    }

    /* ═══ MEMBERSHIP PAGE ═════════════════════════════════════════ */
    #membership {
      background: var(--bg);
      padding: 40px 0 36px;
    }

    .membership-wrapper {
      padding: 0 8vw;
    }

    .membership-header {
      text-align: center;
      margin-bottom: 36px;
    }

    .membership-tiers {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 28px;
      max-width: 860px;
      margin: 0 auto 40px;
    }

    @media(max-width:680px) {
      .membership-tiers {
        grid-template-columns: 1fr;
      }
    }

    .tier-card {
      border-radius: 20px;
      border: 1px solid var(--border);
      background: rgba(255, 255, 255, .03);
      overflow: hidden;
      position: relative;
      transition: transform .25s, box-shadow .25s;
    }

    .tier-card:hover {
      transform: translateY(-5px);
    }

    .tier-card--super {
      border-color: rgba(253, 185, 19, .4);
      background: linear-gradient(160deg, rgba(253, 185, 19, .05), rgba(253, 185, 19, .1), rgba(6, 8, 16, .98));
    }

    .tier-card--super:hover {
      box-shadow: 0 16px 48px rgba(253, 185, 19, .18);
    }

    .tier-card--roar {
      border-color: rgba(0, 71, 160, .4);
    }

    .tier-card--roar:hover {
      box-shadow: 0 16px 48px rgba(0, 71, 160, .18);
    }

    .tier-badge {
      position: absolute;
      top: 16px;
      right: 16px;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 10px;
      letter-spacing: .18em;
      text-transform: uppercase;
      padding: 3px 10px;
      border-radius: 20px;
    }

    .tier-badge--popular {
      background: rgba(253, 185, 19, .2);
      color: var(--gold);
    }

    .tier-badge--value {
      background: rgba(0, 71, 160, .2);
      color: #60a5fa;
    }

    .tier-header {
      padding: 28px 24px 20px;
      border-bottom: 1px solid var(--border);
    }

    .tier-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 28px;
      color: var(--text);
    }

    .tier-price {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 42px;
      line-height: 1;
      margin-top: 8px;
    }

    .tier-price--gold {
      color: var(--gold);
    }

    .tier-price--blue {
      color: #60a5fa;
    }

    .tier-period {
      font-size: 13px;
      color: var(--muted);
      margin-top: 4px;
    }

    .tier-features {
      padding: 20px 24px;
      list-style: none;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .tier-features li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 14px;
      color: var(--muted);
      line-height: 1.4;
    }

    .tier-features li .feat-icon {
      flex-shrink: 0;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      margin-top: 1px;
    }

    .feat-yes {
      background: rgba(74, 222, 128, .15);
      color: #4ade80;
    }

    .feat-no {
      background: rgba(248, 113, 113, .12);
      color: #f87171;
    }

    .tier-cta {
      padding: 20px 24px 28px;
    }

    .tier-btn {
      width: 100%;
      padding: 14px;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 17px;
      letter-spacing: .1em;
      text-transform: uppercase;
      cursor: pointer;
      border-radius: 8px;
      border: none;
      transition: all .2s;
      clip-path: polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%);
    }

    .tier-btn--gold {
      background: var(--gold);
      color: var(--bg);
    }

    .tier-btn--gold:hover {
      background: #ffe040;
    }

    .tier-btn--blue {
      background: #0047a0;
      color: #fff;
    }

    .tier-btn--blue:hover {
      background: #0056c0;
    }

    /* Comparison table */
    .membership-compare {
      max-width: 860px;
      margin: 0 auto 40px;
      overflow-x: auto;
    }

    .compare-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }

    .compare-table th,
    .compare-table td {
      padding: 12px 16px;
      text-align: left;
      border-bottom: 1px solid var(--border);
    }

    .compare-table th {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 16px;
      background: rgba(255, 255, 255, .03);
    }

    .compare-table th:nth-child(2) {
      color: #60a5fa;
    }

    .compare-table th:nth-child(3) {
      color: var(--gold);
    }

    .compare-table td:nth-child(1) {
      color: var(--muted);
    }

    .compare-table td:nth-child(2),
    .compare-table td:nth-child(3) {
      text-align: center;
      font-size: 18px;
    }

    .compare-table tr:hover td {
      background: rgba(255, 255, 255, .02);
    }

    /* FAQ */
    .membership-faq {
      max-width: 680px;
      margin: 0 auto;
    }

    .faq-item {
      border-bottom: 1px solid var(--border);
    }

    .faq-q {
      width: 100%;
      background: none;
      border: none;
      color: var(--text);
      text-align: left;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 17px;
      padding: 16px 0;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
    }

    .faq-q .faq-arrow {
      color: var(--gold);
      font-size: 14px;
      transition: transform .2s;
      flex-shrink: 0;
    }

    .faq-q.open .faq-arrow {
      transform: rotate(180deg);
    }

    .faq-a {
      font-size: 14px;
      color: var(--muted);
      line-height: 1.65;
      max-height: 0;
      overflow: hidden;
      transition: max-height .3s ease, padding .3s;
    }

    .faq-a.open {
      max-height: 200px;
      padding-bottom: 16px;
    }


    /* ═══ FAN ZONE TABS ═══════════════════════════════════════════ */
    .fz-tabs {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .fz-tab {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 15px;
      padding: 10px 20px;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: rgba(255, 255, 255, .04);
      color: var(--muted);
      cursor: pointer;
      transition: .2s;
      clip-path: polygon(6px 0, 100% 0, calc(100% - 6px) 100%, 0 100%);
    }

    .fz-tab:hover {
      color: var(--gold);
      border-color: var(--gold);
    }

    .fz-tab.active {
      background: var(--gold);
      color: var(--bg);
      border-color: var(--gold);
    }

    .fz-panel {
      transition: opacity .2s;
    }

    /* ═══ QUIZ ════════════════════════════════════════════════════ */
    .fz-quiz-card {
      background: rgba(255, 255, 255, .03);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 28px 28px 24px;
      max-width: 680px;
    }

    .fz-quiz-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 16px;
      margin-bottom: 20px;
      flex-wrap: wrap;
    }

    .fz-quiz-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 24px;
      color: var(--text);
    }

    .fz-quiz-sub {
      font-size: 13px;
      color: var(--muted);
      margin-top: 4px;
    }

    .fz-quiz-score-wrap {
      text-align: right;
    }

    .fz-timer {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 32px;
      color: var(--gold);
    }

    .fz-score-label {
      font-size: 13px;
      color: var(--muted);
      margin-top: 4px;
    }

    .fz-q-num {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 13px;
      color: var(--muted);
      letter-spacing: .12em;
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    .fz-q-text {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 20px;
      color: var(--text);
      line-height: 1.3;
      margin-bottom: 20px;
    }

    .fz-options {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .fz-opt {
      padding: 12px 16px;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: rgba(255, 255, 255, .03);
      color: var(--text);
      font-size: 14px;
      cursor: pointer;
      text-align: left;
      transition: .2s;
    }

    .fz-opt:hover {
      border-color: var(--gold);
      background: rgba(253, 185, 19, .06);
    }

    .fz-opt.correct {
      background: rgba(74, 222, 128, .12);
      border-color: #4ade80;
      color: #4ade80;
    }

    .fz-opt.wrong {
      background: rgba(248, 113, 113, .1);
      border-color: #f87171;
      color: #f87171;
    }

    .fz-opt:disabled {
      cursor: default;
      opacity: .7;
    }

    .fz-q-feedback {
      font-size: 13px;
      min-height: 20px;
      margin-top: 12px;
      color: var(--muted);
    }

    .fz-btn-restart {
      margin-top: 16px;
      padding: 12px 28px;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 16px;
      background: var(--gold);
      color: var(--bg);
      border: none;
      border-radius: 8px;
      cursor: pointer;
      clip-path: polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%);
    }

    .fz-lb-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 22px;
      color: var(--gold);
      margin-bottom: 12px;
    }

    .fz-lb-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-bottom: 16px;
    }

    .fz-lb-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 14px;
      border-radius: 8px;
      background: rgba(255, 255, 255, .03);
      border: 1px solid var(--border);
      font-size: 14px;
    }

    .fz-lb-rank {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 20px;
      color: var(--gold);
      width: 24px;
    }

    /* ═══ FIND THE PLAYER ════════════════════════════════════════ */
    .fz-fp-hints {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 16px;
    }

    .fz-fp-hint-item {
      padding: 12px 16px;
      border-radius: 8px;
      border: 1px solid rgba(253, 185, 19, .25);
      background: rgba(253, 185, 19, .06);
      font-size: 14px;
      color: var(--text);
      animation: hintSlide .4s ease;
    }

    @keyframes hintSlide {
      from {
        opacity: 0;
        transform: translateY(-8px);
      }

      to {
        opacity: 1;
        transform: none;
      }
    }

    .fz-fp-reveal {
      padding: 20px;
      border-radius: 12px;
      border: 2px solid var(--gold);
      background: rgba(253, 185, 19, .08);
      text-align: center;
      margin-bottom: 16px;
      animation: revealPop .5s cubic-bezier(.25, .8, .25, 1.3);
    }

    @keyframes revealPop {
      from {
        opacity: 0;
        transform: scale(.85);
      }

      to {
        opacity: 1;
        transform: scale(1);
      }
    }

    .fz-fp-reveal-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 36px;
      color: var(--gold);
    }

    .fz-fp-reveal-role {
      font-size: 13px;
      color: var(--muted);
      margin-top: 4px;
    }

    .fz-fp-input-wrap {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 8px;
    }

    .fz-fp-input {
      flex: 1;
      min-width: 180px;
      padding: 12px 16px;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: rgba(255, 255, 255, .05);
      color: var(--text);
      font-size: 15px;
    }

    .fz-fp-input:focus {
      outline: none;
      border-color: var(--gold);
    }

    .fz-fp-btn {
      padding: 12px 20px;
      border-radius: 8px;
      border: none;
      cursor: pointer;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 15px;
      background: var(--gold);
      color: var(--bg);
      transition: .2s;
    }

    .fz-fp-hint-btn {
      background: rgba(255, 255, 255, .08);
      color: var(--text);
      border: 1px solid var(--border);
    }

    .fz-fp-hint-btn:hover {
      background: rgba(253, 185, 19, .15);
      border-color: var(--gold);
    }

    /* ═══ POLLS ════════════════════════════════════════════════════ */
    .fz-poll-card {
      background: rgba(255, 255, 255, .03);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 20px 24px;
    }

    .fz-poll-q {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 18px;
      color: var(--text);
      margin-bottom: 14px;
    }

    .fz-poll-opt {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 12px;
      border-radius: 8px;
      border: 1px solid var(--border);
      margin-bottom: 8px;
      cursor: pointer;
      position: relative;
      overflow: hidden;
      transition: .2s;
    }

    .fz-poll-opt:hover {
      border-color: var(--gold);
    }

    .fz-poll-bar {
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      background: rgba(253, 185, 19, .1);
      z-index: 0;
      border-radius: 8px;
      transition: width .6s;
    }

    .fz-poll-opt span:first-child {
      position: relative;
      z-index: 1;
      font-size: 13px;
      color: var(--text);
      flex: 1;
    }

    .fz-poll-pct {
      position: relative;
      z-index: 1;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 15px;
      color: var(--gold);
    }

    .fz-poll-votes {
      font-size: 11px;
      color: var(--muted);
      margin-top: 8px;
      text-align: right;
    }

    /* ═══ LEO HOTLINE ══════════════════════════════════════════════ */
    .leo-wrapper {
      display: grid;
      grid-template-columns: 320px 1fr;
      gap: 48px;
      align-items: start;
      width: 100%;
      margin-top: 28px;
    }

    @media(max-width:820px) {
      .leo-wrapper {
        grid-template-columns: 1fr;
      }
    }

    .leo-phone-card {
      display: flex;
      justify-content: center;
    }

    .leo-phone-screen {
      width: 260px;
      min-height: 480px;
      border-radius: 40px;
      background: linear-gradient(170deg, #0d1a2e, #060810);
      border: 2px solid rgba(253, 185, 19, .3);
      box-shadow: 0 0 40px rgba(253, 185, 19, .12), inset 0 0 24px rgba(0, 0, 0, .5);
      padding: 20px 18px 24px;
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .leo-phone-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 11px;
      color: rgba(255, 255, 255, .4);
    }

    .leo-time {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 15px;
      color: var(--text);
    }

    .leo-call-anim {
      text-align: center;
      padding: 24px 0 12px;
      flex: 1;
      position: relative;
    }

    .leo-lion-emoji {
      font-size: 56px;
      margin-bottom: 8px;
    }

    .leo-call-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 26px;
      color: var(--gold);
    }

    .leo-call-label {
      font-size: 13px;
      color: rgba(255, 255, 255, .5);
      margin-top: 6px;
    }

    /* ringing rings */
    .leo-call-rings {
      position: absolute;
      top: 30px;
      left: 50%;
      transform: translateX(-50%);
      width: 90px;
      height: 90px;
      pointer-events: none;
    }

    .leo-ring {
      position: absolute;
      border-radius: 50%;
      border: 2px solid rgba(253, 185, 19, .3);
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      animation: ringPulse 2s ease-out infinite;
    }

    .leo-ring-1 {
      width: 80px;
      height: 80px;
    }

    .leo-ring-2 {
      width: 100px;
      height: 100px;
      animation-delay: .4s;
    }

    .leo-ring-3 {
      width: 120px;
      height: 120px;
      animation-delay: .8s;
    }

    @keyframes ringPulse {
      0% {
        opacity: .6;
        transform: translate(-50%, -50%) scale(.8);
      }

      100% {
        opacity: 0;
        transform: translate(-50%, -50%) scale(1.4);
      }
    }

    .leo-accept-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      width: 60px;
      margin: 0 auto;
      cursor: pointer;
    }

    .leo-accept-icon {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: linear-gradient(135deg, #22c55e, #16a34a);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      box-shadow: 0 4px 16px rgba(34, 197, 94, .4);
      animation: acceptPulse 1.5s ease-in-out infinite;
    }

    @keyframes acceptPulse {

      0%,
      100% {
        transform: scale(1);
        box-shadow: 0 4px 16px rgba(34, 197, 94, .4);
      }

      50% {
        transform: scale(1.08);
        box-shadow: 0 6px 24px rgba(34, 197, 94, .6);
      }
    }

    .leo-accept-txt {
      font-size: 11px;
      color: #22c55e;
      font-weight: 600;
    }

    .leo-msg-bubble {
      background: rgba(253, 185, 19, .1);
      border: 1px solid rgba(253, 185, 19, .25);
      border-radius: 16px;
      padding: 14px;
      flex: 1;
    }

    .leo-msg-bubble--answer {
      background: rgba(0, 71, 160, .15);
      border-color: rgba(0, 71, 160, .35);
    }

    .leo-avatar-row {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 10px;
    }

    .leo-avatar-icon {
      font-size: 20px;
    }

    .leo-avatar-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 15px;
      color: var(--gold);
    }

    .leo-msg-text {
      font-size: 13px;
      color: var(--text);
      line-height: 1.55;
    }

    /* Message panel */
    .leo-msg-panel {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .leo-panel-badge {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 12px;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--gold);
      padding: 4px 14px;
      border: 1px solid rgba(253, 185, 19, .3);
      border-radius: 20px;
      width: fit-content;
      background: rgba(253, 185, 19, .08);
    }

    .leo-panel-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 32px;
      color: var(--text);
      margin: 0;
      line-height: 1.1;
    }

    .leo-topic-tag {
      font-size: 13px;
      color: var(--muted);
      padding: 8px 14px;
      border-radius: 8px;
      background: rgba(255, 255, 255, .04);
      border: 1px solid var(--border);
      width: fit-content;
    }

    .leo-panel-desc {
      font-size: 14px;
      color: var(--muted);
      line-height: 1.65;
      margin: 0;
    }

    .leo-stay-tuned {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 16px;
      color: var(--gold);
      letter-spacing: .08em;
    }

    .leo-form {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .leo-textarea {
      width: 100%;
      min-height: 110px;
      padding: 14px 16px;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: rgba(255, 255, 255, .04);
      color: var(--text);
      font-size: 14px;
      resize: vertical;
      font-family: 'Poppins', sans-serif;
      box-sizing: border-box;
    }

    .leo-textarea:focus {
      outline: none;
      border-color: var(--gold);
    }

    .leo-char-count {
      font-size: 12px;
      color: var(--muted);
      text-align: right;
    }

    .leo-submit-btn {
      padding: 14px 28px;
      width: fit-content;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 18px;
      background: var(--gold);
      color: var(--bg);
      border: none;
      border-radius: 8px;
      cursor: pointer;
      clip-path: polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%);
      transition: .2s;
    }

    .leo-submit-btn:hover {
      background: #ffe040;
    }

    .leo-success {
      font-size: 14px;
      color: #4ade80;
      padding: 12px 16px;
      border-radius: 8px;
      background: rgba(74, 222, 128, .08);
      border: 1px solid rgba(74, 222, 128, .2);
    }

    .leo-prev-q {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .leo-prev-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 16px;
      color: var(--text);
      margin-bottom: 4px;
    }

    .leo-prev-item {
      padding: 12px 14px;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: rgba(255, 255, 255, .02);
    }

    .leo-prev-fan {
      font-size: 12px;
      color: var(--gold);
      font-weight: 600;
      margin-bottom: 4px;
    }

    .leo-prev-text {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.45;
    }
  </style>
</head>

<body>

  <div id="cursor"></div>
  <div id="cursor-ring"></div>

  <!-- NAVBAR -->
  <nav id="navbar">
    <a href="#" class="nav-logo">
      <img
        src="data:image/jpeg;base64,"
        alt="CSK Logo">
    </a>
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
    <ul class="nav-links" id="nav-links">
      <li><a href="#legacy">Legacy</a></li>
      <li><a href="#yearwise-squad">Squad</a></li>
      <li><a href="#fixtures">Fixtures</a></li>
      <li><a href="#titles">Titles</a></li>
      <li><a href="#membership" class="nav-highlight">Membership</a></li>
      <li><a href="#fanzone">Fan Zone</a></li>
      <li><a href="#leo-hotline">Leo Hotline</a></li>
    </ul>
    <div class="nav-right">
      <div class="live-badge">
        <div class="live-dot"></div>
        Live
      </div>
      <a href="#membership" class="btn-angled">Join Now</a>
    </div>
  </nav>


  <!-- HERO -->
  <section id="hero">
    <div class="hero-grid"></div>
    <div class="hero-radial"></div>
    <div class="hero-bg-name">MS&nbsp;DHONI</div>
    <div class="hero-glow"></div>
    <div class="hero-content reveal">
      <div class="hero-tag">IPL 2025 Season</div>
      <div class="hero-name">MS<br><span>Dhoni</span></div>
      <div class="hero-role">Captain · Wicketkeeper · Icon</div>
      <div class="stat-chips">
        <div class="chip">
          <div class="chip-val">5</div>
          <div class="chip-label">IPL Titles</div>
        </div>
        <div class="chip">
          <div class="chip-val">250+</div>
          <div class="chip-label">Matches</div>
        </div>
        <div class="chip">
          <div class="chip-val">4,978</div>
          <div class="chip-label">Runs</div>
        </div>
        <div class="chip">
          <div class="chip-val">99+</div>
          <div class="chip-label">Stumpings</div>
        </div>
      </div>
      <a href="#squad2026" class="btn-angled">Meet The Squad</a>
    </div>
    <div class="hero-player">
      <img
        src="data:image/avif;base64,"
        alt="MS Dhoni" id="hero-img">
    </div>
  </section>

  <!-- MARQUEE -->
  <div class="marquee-strip">
    <div class="marquee-track" id="marquee-track"></div>
  </div>

  <!-- LIVE TICKER -->
  <div class="ticker-bar">
    <div class="ticker-label">🔴 Live Scores</div>
    <div class="ticker-scroll">
      <div class="ticker-inner" id="ticker-inner"></div>
    </div>
  </div>

  <!-- LEGACY -->
  <section id="legacy">
    <div class="section-tag">Our Story</div>
    <div class="legacy-layout">
      <div class="legacy-text">
        <div class="section-title reveal">The<br><span>Legacy</span></div>
        <p class="reveal reveal-delay-1">Founded in 2008, Chennai Super Kings has grown into one of the most successful
          and beloved franchises in cricket history. Led for most of its journey by the legendary MS Dhoni, CSK became
          more than just a team—it became an emotion that unites millions of fans across the globe. With five IPL
          championships, two Champions League T20 titles, and a record of consistent excellence, the Men in Yellow have
          set the benchmark for success, resilience, and loyalty. Through triumphs, comebacks, and unforgettable
          moments, CSK has built a legacy that transcends generations.
        </p>
        <p class="reveal reveal-delay-2">"Whistle Podu" is not just a slogan—it's the heartbeat of a global family that
          proudly wears yellow and celebrates the spirit of Chennai Super Kings.</p>
        <div class="gold-line reveal reveal-delay-3"></div>
      </div>
      <div class="legacy-stats reveal reveal-delay-2">
        <div class="lstat">
          <div class="lstat-val">5</div>
          <div class="lstat-label">IPL Championships</div>
        </div>
        <div class="lstat">
          <div class="lstat-val">12</div>
          <div class="lstat-label">Playoff Seasons</div>
        </div>
        <div class="lstat">
          <div class="lstat-val">148</div>
          <div class="lstat-label">Wins in IPL</div>
        </div>
        <div class="lstat">
          <div class="lstat-val">2008</div>
          <div class="lstat-label">Year Founded</div>
        </div>
      </div>
    </div>
  </section>

  <!-- YEAR-WISE SQUAD -->
  <section id="yearwise-squad" style="background:var(--bg);padding:40px 0 28px;">
    <div style="padding:0 8vw 32px;">
      <div class="section-tag reveal">All Seasons</div>
      <div
        style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:32px;">
        <div class="section-title reveal" style="margin-bottom:0">Year-Wise<br><span>Squad</span></div>
        <div style="display:flex;align-items:center;gap:24px;flex-wrap:wrap;">
          <div class="yw-controls reveal reveal-delay-1">
            <label class="yw-label" for="yw-select">Select Season</label>
            <div class="yw-select-wrap">
              <select id="yw-select" class="yw-select">
                <option value="2026">IPL 2026</option>
                <option value="2025">IPL 2025</option>
                <option value="2024">IPL 2024</option>
                <option value="2023">IPL 2023</option>
                <option value="2022">IPL 2022</option>
                <option value="2021">IPL 2021</option>
                <option value="2020">IPL 2020</option>
                <option value="2019">IPL 2019</option>
                <option value="2018">IPL 2018</option>
                <option value="2015">IPL 2015</option>
                <option value="2014">IPL 2014</option>
                <option value="2013">IPL 2013</option>
                <option value="2012">IPL 2012</option>
                <option value="2011">IPL 2011</option>
                <option value="2010">IPL 2010</option>
                <option value="2009">IPL 2009</option>
                <option value="2008">IPL 2008</option>
              </select>
              <div class="yw-select-icon">▾</div>
            </div>
          </div>
          <!-- Carousel controls -->
          <div class="sq26-carousel-controls reveal reveal-delay-1">
            <button class="sq26-btn" id="yw-prev" aria-label="Previous">&#8592;</button>
            <div class="sq26-dots" id="yw-dots"></div>
            <button class="sq26-btn" id="yw-next" aria-label="Next">&#8594;</button>
          </div>
        </div>
      </div>
      <div class="yw-season-strip" id="yw-season-strip">
        <div class="yw-season-year" id="yw-season-year">2026</div>
        <div class="yw-season-label" id="yw-season-label">Current Season</div>
      </div>
    </div>
    <div class="sq26-carousel-outer">
      <div class="sq26-track" id="yw-track">
        <!-- Populated by JS -->
      </div>
    </div>
  </section>

  <!-- SQUAD 2026 CAROUSEL -->
  <section id="squad2026" style="background:var(--bg2);padding:40px 0 28px;">
    <div style="padding:0 8vw 32px;">
      <div class="section-tag reveal">IPL 2026 Roster · 30 Players</div>
      <div
        style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:24px;">
