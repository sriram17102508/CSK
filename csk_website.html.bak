        { name: "Matt Henry", role: "Bowler", type: "bowl", num: 21, color: "#d9f99d", initials: "MH", photo: false },
      ],
    };

    const YEAR_LABELS = { "2008": "Inaugural Season", "2009": "South Africa Edition", "2010": "IPL Champions", "2011": "Back-to-Back Kings", "2012": "Finals Appearance", "2013": "Finals Again", "2014": "Playoff Warriors", "2015": "Finals Streak", "2018": "Return of Kings", "2019": "One Run Away", "2020": "Rare Off Season", "2021": "Fourth Crown", "2022": "Transition Year", "2023": "Five-Star Kings", "2024": "New Era", "2025": "The Hunt Continues", "2026": "Current Season" };
    const DHONI_SRC = "1.png"
    function buildYearSquad(year) {
      var grid = document.getElementById('yw-grid');
      var yearEl = document.getElementById('yw-season-year');
      var labelEl = document.getElementById('yw-season-label');
      if (!grid) return;
      var players = YEARWISE_SQUADS[year] || [];
      if (yearEl) yearEl.textContent = year;
      if (labelEl) labelEl.textContent = YEAR_LABELS[year] || ('IPL ' + year);
      grid.style.opacity = '0';
      setTimeout(function () {
        grid.innerHTML = '';
        var typeIcons = { bat: '🏏', wk: '🧤', ar: '⚡', bowl: '🎯' };
        var typeLabels = { bat: 'BAT 🏏', wk: 'WK 🧤', ar: 'AR ⚡', bowl: 'BWL 🎯' };
        players.forEach(function (p) {
          var card = document.createElement('div');
          card.className = 'yw-player-card';
          card.style.borderColor = p.color + '44';

          var usePhoto = (p.photo === true && year === '2026');
          var topHtml;
          if (usePhoto) {
            topHtml = '<img class="yw-card-photo" src="' + DHONI_SRC + '" alt="' + p.name + '">';
          } else {
            topHtml =
              '<div class="yw-card-av" style="background:linear-gradient(160deg,' + p.color + '18,' + p.color + '30,rgba(6,8,16,.97))">' +
              '<div class="yw-card-jersey" style="color:' + p.color + '">' + p.num + '</div>' +
              '<div class="yw-card-initials" style="color:' + p.color + ';border-color:' + p.color + '55">' + p.initials + '</div>' +
              '<div class="yw-card-icon">' + (typeIcons[p.type] || '') + '</div>' +
              '</div>';
          }

          card.innerHTML =
            '<div class="yw-card-top">' +
            topHtml +
            '<div class="yw-type-tag" style="background:' + p.color + '22;border-color:' + p.color + '44;color:' + p.color + '">' + (typeLabels[p.type] || p.type) + '</div>' +
            '</div>' +
            '<div class="yw-card-info">' +
            '<div class="yw-card-num" style="color:' + p.color + '">#' + p.num + '</div>' +
            '<div class="yw-card-name">' + p.name + '</div>' +
            '<div class="yw-card-role">' + p.role + '</div>' +
            '</div>';
          grid.appendChild(card);
        });
        grid.style.opacity = '1';
      }, 180);
    }

    // Initialise
    try { buildYearSquad('2026'); } catch (e) { console.warn('YW squad init:', e); }
    var _ywSel = document.getElementById('yw-select');
    if (_ywSel) _ywSel.addEventListener('change', function () { try { buildYearSquad(_ywSel.value); } catch (e) { } });



    // ═══ HAMBURGER MENU ════════════════════════════════════════════
    (function () {
      var btn = document.getElementById('nav-hamburger');
      var links = document.getElementById('nav-links');
      if (!btn || !links) return;
      btn.addEventListener('click', function () {
        btn.classList.toggle('active');
        links.classList.toggle('open');
      });
      links.querySelectorAll('a').forEach(function (a) {
        a.addEventListener('click', function () {
          btn.classList.remove('active');
          links.classList.remove('open');
        });
      });
    })();

    // ═══ FAQ ACCORDION ══════════════════════════════════════════════
    function toggleFaq(btn) {
      var answer = btn.nextElementSibling;
      var isOpen = btn.classList.contains('open');
      // close all
      document.querySelectorAll('.faq-q.open').forEach(function (q) {
        q.classList.remove('open');
        q.nextElementSibling.classList.remove('open');
      });
      if (!isOpen) {
        btn.classList.add('open');
        answer.classList.add('open');
      }
    }



    // ═══ FAN ZONE TABS ════════════════════════════════════════════
    function fzTab(btn, panelId) {
      document.querySelectorAll('.fz-tab').forEach(function (b) { b.classList.remove('active'); });
      document.querySelectorAll('.fz-panel').forEach(function (p) { p.style.display = 'none'; });
      btn.classList.add('active');
      var panel = document.getElementById(panelId);
      if (panel) panel.style.display = 'block';
    }

    // ═══ QUIZ ═════════════════════════════════════════════════════
    var FZ_QUESTIONS = [
      { q: "In which year did CSK win their first IPL title?", opts: ["2008", "2010", "2011", "2013"], ans: 1 },
      { q: "Who is CSK's most iconic captain?", opts: ["Sourav Ganguly", "MS Dhoni", "Virat Kohli", "Suresh Raina"], ans: 1 },
      { q: "What is CSK's home ground?", opts: ["Wankhede Stadium", "M.A. Chidambaram Stadium", "Eden Gardens", "Feroz Shah Kotla"], ans: 1 },
      { q: "How many IPL titles has CSK won (as of 2026)?", opts: ["4", "5", "6", "7"], ans: 1 },
      { q: "What are CSK's team colours?", opts: ["Blue and Red", "Yellow and Blue", "Gold and Black", "Green and Gold"], ans: 1 },
      { q: "Which player scored a match-winning century in the 2018 IPL final?", opts: ["Faf du Plessis", "Suresh Raina", "Shane Watson", "MS Dhoni"], ans: 2 },
      { q: "CSK's famous fan chant is called?", opts: ["Yellow Thunder", "Whistle Podu", "Thala Magic", "Super Storm"], ans: 1 },
      { q: "In which year was CSK suspended from the IPL?", opts: ["2014", "2015", "2016", "2017"], ans: 2 },
      { q: "Who took the last-over wickets to win the 2023 IPL final for CSK?", opts: ["Deepak Chahar", "Shardul Thakur", "Ravindra Jadeja", "Dwayne Bravo"], ans: 2 },
      { q: "CSK's mascot is a?", opts: ["Tiger", "Elephant", "Lion", "Cheetah"], ans: 2 }
    ];
    var fzQIdx = 0, fzScore = 0, fzTimer = null, fzTimeLeft = 60, fzAnswered = false;
    var fzLB = [
      { name: "@YellowArmy", score: 10 },
      { name: "@WhistlePodu", score: 9 },
      { name: "@Thala4Ever", score: 9 },
      { name: "@ChepaukKing", score: 8 },
      { name: "@SuperFan7", score: 7 }
    ];

    function fzQuizStart() {
      fzQIdx = 0; fzScore = 0; fzTimeLeft = 60; fzAnswered = false;
      var lb = document.getElementById('fz-leaderboard');
      var qb = document.getElementById('fz-quiz-body');
      if (lb) lb.style.display = 'none';
      if (qb) qb.style.display = 'block';
      document.getElementById('fz-score').textContent = '0';
      fzRenderQ();
      fzStartTimer();
    }
    function fzRenderQ() {
      if (fzQIdx >= FZ_QUESTIONS.length) { fzQuizEnd(); return; }
      var q = FZ_QUESTIONS[fzQIdx];
      fzAnswered = false;
      document.getElementById('fz-qnum').textContent = 'Question ' + (fzQIdx + 1) + ' of ' + FZ_QUESTIONS.length;
      document.getElementById('fz-qtext').textContent = q.q;
      document.getElementById('fz-feedback').textContent = '';
      var opts = document.getElementById('fz-options');
      opts.innerHTML = '';
      q.opts.forEach(function (opt, i) {
        var btn = document.createElement('button');
        btn.className = 'fz-opt'; btn.textContent = opt;
        btn.onclick = function () { fzAnswer(i, btn); };
        opts.appendChild(btn);
      });
    }
    function fzAnswer(idx, btn) {
      if (fzAnswered) return;
      fzAnswered = true;
      var q = FZ_QUESTIONS[fzQIdx];
      var opts = document.querySelectorAll('.fz-opt');
      opts.forEach(function (b) { b.disabled = true; });
      if (idx === q.ans) {
        btn.classList.add('correct'); fzScore++;
        document.getElementById('fz-score').textContent = fzScore;
        document.getElementById('fz-feedback').textContent = '✅ Correct! Well done!';
      } else {
        btn.classList.add('wrong');
        opts[q.ans].classList.add('correct');
        document.getElementById('fz-feedback').textContent = '❌ Wrong! The answer was: ' + q.opts[q.ans];
      }
      setTimeout(function () { fzQIdx++; fzRenderQ(); }, 1400);
    }
    function fzStartTimer() {
      clearInterval(fzTimer);
      fzTimer = setInterval(function () {
        fzTimeLeft--;
        var m = Math.floor(fzTimeLeft / 60), s = fzTimeLeft % 60;
        var el = document.getElementById('fz-timer');
        if (el) el.textContent = (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;
        if (fzTimeLeft <= 0) { clearInterval(fzTimer); fzQuizEnd(); }
      }, 1000);
    }
    function fzQuizEnd() {
      clearInterval(fzTimer);
      var qb = document.getElementById('fz-quiz-body');
      var lb = document.getElementById('fz-leaderboard');
      if (qb) qb.style.display = 'none';
      if (lb) { lb.style.display = 'block'; }
      var name = 'You';
      fzLB.push({ name: name, score: fzScore });
      fzLB.sort(function (a, b) { return b.score - a.score; });
      fzLB = fzLB.slice(0, 5);
      var list = document.getElementById('fz-lb-list');
      if (list) {
        list.innerHTML = '';
        fzLB.forEach(function (e, i) {
          var d = document.createElement('div'); d.className = 'fz-lb-item';
          d.innerHTML = '<div class="fz-lb-rank">' + (i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : (i + 1) + '.') + '</div><div style="flex:1">' + e.name + '</div><div style="color:var(--gold);font-weight:700">' + e.score + '/10</div>';
          list.appendChild(d);
        });
      }
    }
    function fzQuizRestart() { fzQuizStart(); }

    // ═══ FIND THE PLAYER ══════════════════════════════════════════
    var FP_PLAYERS = [
      { name: "MS Dhoni", hints: ["Wears jersey #7", "Famous for helicopter shot", "Captain of CSK since 2008", "Known as Thala by fans", "Wicket-keeper batter from Jharkhand"] },
      { name: "Ruturaj Gaikwad", hints: ["Current CSK captain in 2026", "Orange Cap winner in 2021", "From Pune, Maharashtra", "Right-handed opening batter", "Wears jersey #31"] },
      { name: "Ravindra Jadeja", hints: ["Left-arm spinner", "Brilliant fielder — runs people out for fun", "Also a batter who finishes games", "From Saurashtra, Gujarat", "Nicknamed Sir Jadeja"] },
      { name: "Suresh Raina", hints: ["Mr. IPL — always scored when CSK needed", "Left-handed middle-order batter", "First to 5000 IPL runs", "Wore jersey #3", "Retired CSK legend from Uttar Pradesh"] },
      { name: "Dwayne Bravo", "hints": ["West Indian all-rounder", "Champion — his IPL theme song", "Multiple Purple Cap winner", "Wears/wore jersey #47", "Known for death-overs bowling"] }
    ];
    var fpIdx = 0, fpHintIdx = 0, fpSolved = false;

    function fpLoad() {
      fpHintIdx = 0; fpSolved = false;
      var p = FP_PLAYERS[fpIdx % FP_PLAYERS.length];
      var hl = document.getElementById('fp-hints-list');
      var rv = document.getElementById('fp-reveal');
      var fb = document.getElementById('fp-feedback');
      var inp = document.getElementById('fp-guess');
      if (hl) hl.innerHTML = '';
      if (rv) rv.style.display = 'none';
      if (fb) { fb.textContent = ''; fb.className = 'fz-q-feedback'; }
      if (inp) inp.value = '';
      fpAddHint();
    }
    function fpAddHint() {
      var p = FP_PLAYERS[fpIdx % FP_PLAYERS.length];
      if (fpHintIdx >= p.hints.length) return;
      var hl = document.getElementById('fp-hints-list');
      if (!hl) return;
      var d = document.createElement('div'); d.className = 'fz-fp-hint-item';
      d.innerHTML = '<strong>Hint ' + (fpHintIdx + 1) + ':</strong> ' + p.hints[fpHintIdx];
      hl.appendChild(d);
      fpHintIdx++;
    }
    function fpHint() { fpAddHint(); }
    function fpSubmit() {
      if (fpSolved) return;
      var p = FP_PLAYERS[fpIdx % FP_PLAYERS.length];
      var inp = document.getElementById('fp-guess');
      var fb = document.getElementById('fp-feedback');
      if (!inp || !fb) return;
      var guess = inp.value.trim().toLowerCase();
      if (!guess) return;
      if (guess.indexOf(p.name.split(' ')[0].toLowerCase()) !== -1 || guess.indexOf(p.name.toLowerCase()) !== -1) {
        fpSolved = true;
        var rv = document.getElementById('fp-reveal');
        if (rv) {
          rv.style.display = 'block';
          rv.innerHTML = '<div style="font-size:40px;margin-bottom:8px;">🎉</div><div class="fz-fp-reveal-name">' + p.name + '</div><div class="fz-fp-reveal-role">You got it!</div>';
        }
        fb.textContent = '✅ Correct! Amazing!';
        fb.style.color = '#4ade80';
      } else {
        fb.textContent = '❌ Try again! Use another hint.';
        fb.style.color = '#f87171';
        fpAddHint();
      }
      inp.value = '';
    }
    function fpNext() { fpIdx++; fpLoad(); }

    // ═══ POLLS ════════════════════════════════════════════════════
    function fzVote(el, pct) {
      var bar = el.querySelector('.fz-poll-bar');
      var pctEl = el.querySelector('.fz-poll-pct');
      if (bar) bar.style.background = 'rgba(253,185,19,.25)';
      el.style.borderColor = 'var(--gold)';
    }

    // ═══ LEO CLOCK + HOTLINE ══════════════════════════════════════
    (function () {
      function updateClock() {
        var d = new Date();
        var h = d.getHours(), m = d.getMinutes();
        var el = document.getElementById('leo-clock');
        if (el) el.textContent = (h < 10 ? '0' : '') + h + ':' + (m < 10 ? '0' : '') + m;
      }
      updateClock(); setInterval(updateClock, 30000);
    })();

    var leoAnswered = false;
    function leoAnswer() {
      if (leoAnswered) return;
      leoAnswered = true;
      var anim = document.getElementById('leo-call-anim');
      var msg1 = document.getElementById('leo-msg-bubble');
      var msg2 = document.getElementById('leo-msg-answer');
      var acc = document.getElementById('leo-accept');
      var lbl = document.getElementById('leo-call-label');
      if (lbl) lbl.textContent = 'Connected!';
      if (acc) acc.style.display = 'none';
      setTimeout(function () {
        if (anim) anim.style.display = 'none';
        if (msg1) msg1.style.display = 'block';
        setTimeout(function () {
          if (msg2) msg2.style.display = 'block';
        }, 1200);
      }, 600);
    }
    function leoCount(el) {
      var c = document.getElementById('leo-chars');
      if (c) c.textContent = el.value.length;
    }
    function leoSubmit() {
      var q = document.getElementById('leo-question');
      var s = document.getElementById('leo-submitted');
      if (!q || !q.value.trim()) { alert('Please type your question first!'); return; }
      if (s) { s.style.display = 'block'; }
      q.value = '';
      var c = document.getElementById('leo-chars');
      if (c) c.textContent = '0';
    }

    // Init
    fzQuizStart();
    fpLoad();

  </script>
</body>

</html>