  <section id="leo-hotline" style="background:var(--bg);padding:40px 0 36px;">
    <div style="padding:0 8vw;">
      <div class="section-tag reveal">Leo's Den</div>
      <div class="section-title reveal">Leo<br><span>Hotline</span></div>

      <div class="leo-wrapper reveal">
        <!-- Phone card -->
        <div class="leo-phone-card">
          <div class="leo-phone-screen">
            <div class="leo-phone-top">
              <div class="leo-signal">▌▌▌</div>
              <div class="leo-time" id="leo-clock">10:41</div>
              <div class="leo-battery">🔋</div>
            </div>
            <div class="leo-call-anim" id="leo-call-anim">
              <div class="leo-lion-emoji">🦁</div>
              <div class="leo-call-name">Leo</div>
              <div class="leo-call-label" id="leo-call-label">Tring... Tring!</div>
              <div class="leo-call-rings">
                <div class="leo-ring leo-ring-1"></div>
                <div class="leo-ring leo-ring-2"></div>
                <div class="leo-ring leo-ring-3"></div>
              </div>
            </div>
            <div class="leo-msg-bubble" id="leo-msg-bubble" style="display:none;">
              <div class="leo-avatar-row">
                <div class="leo-avatar-icon">🦁</div>
                <div class="leo-avatar-name">Leo</div>
              </div>
              <div class="leo-msg-text">Hello, who is it?</div>
            </div>
            <div class="leo-msg-bubble leo-msg-bubble--answer" id="leo-msg-answer" style="display:none;">
              <div class="leo-avatar-row">
                <div class="leo-avatar-icon">🦁</div>
                <div class="leo-avatar-name">Leo</div>
              </div>
              <div class="leo-msg-text" id="leo-answer-text">Hello Superfans! It's your very own Leo from the Lion's
                Den. Been feeling all your Yellove from the stands during the season — thought why not have a little
                chat off the field!</div>
            </div>
            <div class="leo-accept-btn" id="leo-accept" onclick="leoAnswer()">
              <div class="leo-accept-icon">📞</div>
              <div class="leo-accept-txt">Accept</div>
            </div>
          </div>
        </div>

        <!-- Message panel -->
        <div class="leo-msg-panel">
          <div class="leo-panel-badge">📣 SUPERFANS!!</div>
          <h2 class="leo-panel-title">Shoot Your Questions</h2>
          <div class="leo-topic-tag">This week's topic: <strong>2026 IPL Auction</strong></div>
          <p class="leo-panel-desc">
            I am sure you have got several questions for me.<br>
            So, what are you waiting for?<br>
            <em>Shoot in your questions and we will get back to you.</em>
          </p>
          <div class="leo-stay-tuned">📺 STAY TUNED!</div>

          <div class="leo-form">
            <textarea id="leo-question" class="leo-textarea" placeholder="Type your question here..." maxlength="500"
              oninput="leoCount(this)"></textarea>
            <div class="leo-char-count"><span id="leo-chars">0</span> / 500</div>
            <button class="leo-submit-btn" onclick="leoSubmit()">Submit Question 🦁</button>
          </div>

          <div id="leo-submitted" style="display:none;" class="leo-success">
            ✅ Question submitted! Leo will get back to you. Whistle Podu! 🦁
          </div>

        </div>
      </div>
    </div>
  </section>

