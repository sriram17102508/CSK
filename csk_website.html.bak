  <script>
    // CURSOR
    const cursor = document.getElementById('cursor');
    const ring = document.getElementById('cursor-ring');
    let mx = 0, my = 0, rx = 0, ry = 0;
    document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; cursor.style.left = mx + 'px'; cursor.style.top = my + 'px'; });
    function animRing() { rx += (mx - rx) * 0.12; ry += (my - ry) * .12; ring.style.left = rx + 'px'; ring.style.top = ry + 'px'; requestAnimationFrame(animRing); }
    animRing();
    document.querySelectorAll('a,button,.squad-card,.fan-card,.title-block').forEach(el => {
      el.addEventListener('mouseenter', () => { ring.style.width = '60px'; ring.style.height = '60px'; ring.style.borderColor = 'rgba(253,185,19,0.8)'; });
      el.addEventListener('mouseleave', () => { ring.style.width = '36px'; ring.style.height = '36px'; ring.style.borderColor = 'var(--gold)'; });
    });

    // NAVBAR SCROLL
    window.addEventListener('scroll', () => {
      document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 40);
    });

    // PARALLAX HERO
    window.addEventListener('scroll', () => {
      const s = window.scrollY;
      const heroImg = document.getElementById('hero-img');
      const bgName = document.querySelector('.hero-bg-name');
      if (!heroImg) return;
      if (heroImg) heroImg.style.transform = `translateY(${s * 0.25}px)`;
      if (bgName) bgName.style.transform = `translate(-50%, calc(-50% + ${s * 0.1}px))`;
    });

    // MARQUEE
    const items = ['Whistle Podu', '5x IPL Champions', 'The Yellow Army', 'Thala for a Reason', 'Chepauk Fortress', 'CSK Forever', 'Est. 2008', 'Lion of Chennai'];
    const track = document.getElementById('marquee-track');
    if (track) {
      const doubled = [...items, ...items, ...items, ...items];
      doubled.forEach(t => { const el = document.createElement('div'); el.className = 'marquee-item'; el.textContent = t; track.appendChild(el); });
    }

    // TICKER
    const matches = [
      'CSK 185/4 vs MI 162/8 — CSK WON by 23 runs',
      'RCB 178/6 vs CSK 181/3 — CSK WON by 7 wkts',
      'DC 155/9 vs CSK 158/5 — CSK WON by 5 wkts',
      'CSK 201/4 vs KKR 197/7 — CSK WON by 4 runs',
      'GT 175/5 vs CSK 176/3 — CSK WON by 7 wkts',
    ];
    const ticker = document.getElementById('ticker-inner');
    if (ticker) {
      var tDoubled = [...matches, ...matches];
      tDoubled.forEach(function (m) {
        var el = document.createElement('div');
        el.className = 'ticker-match';
        el.innerHTML = '<span class="tscore">' + m + '</span>';
        ticker.appendChild(el);
      });
    }

    // SCROLL REVEAL
    const observer = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // TIMELINE DRAG SCROLL
    const tlScroll = document.getElementById('timeline-scroll');
    if (tlScroll) {
      let isDown = false, startX, scrollLeft;
      tlScroll.addEventListener('mousedown', e => { isDown = true; startX = e.pageX - tlScroll.offsetLeft; scrollLeft = tlScroll.scrollLeft; });
      tlScroll.addEventListener('mouseleave', () => isDown = false);
      tlScroll.addEventListener('mouseup', () => isDown = false);
      tlScroll.addEventListener('mousemove', e => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - tlScroll.offsetLeft;
        tlScroll.scrollLeft = scrollLeft - (x - startX) * 1.5;
      });
    }

    // ═══════════════════════════════════════════════════
    //  PLAYERS ARCHIVE DATA
    // ═══════════════════════════════════════════════════
    const PLAYERS = {
      2008: { players: ['MS Dhoni', 'Suresh Raina', 'Matthew Hayden', 'Michael Hussey', 'Stephen Fleming', 'Muttiah Muralitharan', 'Albie Morkel', 'Jacob Oram', 'Parthiv Patel', 'Subramaniam Badrinath', 'Joginder Sharma', 'Lakshmipathy Balaji', 'Manpreet Gony', 'Ravichandran Ashwin', 'Makhaya Ntini', 'Vidyut Sivaramakrishnan', 'Shadab Jakati', 'Sudeep Tyagi', 'Abhinav Mukund', 'Anirudha Srikkanth'], captain: 'MS Dhoni' },
