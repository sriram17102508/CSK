    // ═══ YEAR-WISE SQUAD ════════════════════════════════════════
    const YEARWISE_SQUADS = {
      "2008": [
        { name: "MS Dhoni", role: "WK-Batter", type: "wk", num: 7, color: "#FDB913", initials: "MD", photo: false },
